---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  pathname?: string;
  type?: 'website' | 'article';
  headerVariant?: 'transparent' | 'solid';
}

const {
  title,
  description = 'Gabriel: Bíblia e Devocional — Sua jornada espiritual, todos os dias.',
  image = '/og-image.png',
  pathname,
  type = 'website',
  headerVariant = 'solid',
} = Astro.props;

const resolvedPathname = pathname ?? Astro.url.pathname;
const canonicalURL = new URL(resolvedPathname, Astro.site ?? 'https://gabriel.vhxco.com');
const ogImageURL = new URL(image, Astro.site ?? 'https://gabriel.vhxco.com');
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Theme color -->
    <meta name="theme-color" content="#1E3A5F" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Gabriel" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Preload critical fonts (Inter 400 + Lora 700 latin) -->
    <link rel="preload" href="/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/lora-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <title>{title}</title>
  </head>

  <body class="font-sans text-celestial-700 bg-white min-h-dvh flex flex-col antialiased">

    <!-- Skip to content (a11y) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-celestial-700 focus:text-white focus:rounded-xl focus:text-sm focus:font-medium focus:shadow-soft"
    >
      Ir para o conteúdo
    </a>

    <!-- Header -->
    <header
      id="site-header"
      data-variant={headerVariant}
      class:list={[
        'sticky top-0 z-40 transition-all duration-300',
        headerVariant === 'solid'
          ? 'bg-celestial-700/95 backdrop-blur-md shadow-soft'
          : 'bg-transparent',
      ]}
    >
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo wordmark -->
          <a
            href="/"
            class="font-serif font-bold text-xl tracking-tight transition-opacity hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-2 rounded"
            class:list={[
              headerVariant === 'solid' ? 'text-white' : 'text-celestial-700',
              'header-logo'
            ]}
            aria-label="Gabriel — Página inicial"
          >
            Gabriel
          </a>

          <!-- Nav legal links -->
          <nav aria-label="Links legais">
            <ul class="flex items-center gap-1 sm:gap-2">
              <li>
                <a
                  href="/privacy"
                  class="text-xs sm:text-sm font-medium px-2 sm:px-3 py-1.5 rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1"
                  class:list={[
                    headerVariant === 'solid'
                      ? 'text-celestial-100 hover:text-white hover:bg-white/10'
                      : 'text-celestial-600 hover:text-celestial-800 hover:bg-celestial-50',
                    'header-nav-link'
                  ]}
                >
                  Privacidade
                </a>
              </li>
              <li>
                <a
                  href="/terms"
                  class="text-xs sm:text-sm font-medium px-2 sm:px-3 py-1.5 rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1"
                  class:list={[
                    headerVariant === 'solid'
                      ? 'text-celestial-100 hover:text-white hover:bg-white/10'
                      : 'text-celestial-600 hover:text-celestial-800 hover:bg-celestial-50',
                    'header-nav-link'
                  ]}
                >
                  Termos
                </a>
              </li>
              <li>
                <a
                  href="/delete-account"
                  class="text-xs sm:text-sm font-medium px-2 sm:px-3 py-1.5 rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1"
                  class:list={[
                    headerVariant === 'solid'
                      ? 'text-celestial-100 hover:text-white hover:bg-white/10'
                      : 'text-celestial-600 hover:text-celestial-800 hover:bg-celestial-50',
                    'header-nav-link'
                  ]}
                >
                  Excluir Conta
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-celestial-700 text-celestial-100">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
          <!-- Wordmark + copy -->
          <div>
            <p class="font-serif font-semibold text-white text-lg mb-1">Gabriel</p>
            <p class="text-celestial-300 text-xs">
              &copy; {year} <a href="https://vhxco.com.br" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors underline underline-offset-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1 rounded">VHXCO</a>.
              Todos os direitos reservados.
            </p>
          </div>

          <!-- Links legais -->
          <nav aria-label="Links legais do rodapé">
            <ul class="flex flex-wrap gap-x-4 gap-y-1">
              <li>
                <a href="/privacy" class="text-xs text-celestial-300 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1 rounded">
                  Privacidade
                </a>
              </li>
              <li>
                <a href="/terms" class="text-xs text-celestial-300 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1 rounded">
                  Termos de Uso
                </a>
              </li>
              <li>
                <a href="/delete-account" class="text-xs text-celestial-300 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1 rounded">
                  Excluir Conta
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </footer>

    <!-- Header scroll behavior: transparent → solid (only when headerVariant='transparent') -->
    <script>
      const header = document.getElementById('site-header');
      if (header && header.dataset.variant === 'transparent') {
        const logoEl = header.querySelector('.header-logo');
        const navLinks = header.querySelectorAll('.header-nav-link');

        function applyScrollState() {
          const scrolled = window.scrollY > 20;
          if (scrolled) {
            header!.classList.add('bg-celestial-700/95', 'backdrop-blur-md', 'shadow-soft');
            header!.classList.remove('bg-transparent');
            logoEl?.classList.replace('text-celestial-700', 'text-white');
            navLinks.forEach((link) => {
              link.classList.remove('text-celestial-600', 'hover:text-celestial-800', 'hover:bg-celestial-50');
              link.classList.add('text-celestial-100', 'hover:text-white', 'hover:bg-white/10');
            });
          } else {
            header!.classList.remove('bg-celestial-700/95', 'backdrop-blur-md', 'shadow-soft');
            header!.classList.add('bg-transparent');
            logoEl?.classList.replace('text-white', 'text-celestial-700');
            navLinks.forEach((link) => {
              link.classList.remove('text-celestial-100', 'hover:text-white', 'hover:bg-white/10');
              link.classList.add('text-celestial-600', 'hover:text-celestial-800', 'hover:bg-celestial-50');
            });
          }
        }

        window.addEventListener('scroll', applyScrollState, { passive: true });
        applyScrollState();
      }
    </script>
  </body>
</html>
