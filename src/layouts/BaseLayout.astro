---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  pathname?: string;
  type?: 'website' | 'article';
  headerVariant?: 'transparent' | 'solid';
}

const {
  title,
  description = 'Gabriel: Bíblia e Devocional — Sua jornada espiritual, todos os dias.',
  image = '/og-image.png',
  pathname,
  type = 'website',
  headerVariant = 'solid',
} = Astro.props;

const resolvedPathname = pathname ?? Astro.url.pathname;
const canonicalURL = new URL(resolvedPathname, Astro.site ?? 'https://gabriel.vhxco.com');
const ogImageURL = new URL(image, Astro.site ?? 'https://gabriel.vhxco.com');
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Theme color — paper (ADR-0015 §5.1) -->
    <meta name="theme-color" content="#FAF7F0" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Gabriel" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Preload critical fonts: Fraunces (display critical — wordmark FCP) + Inter 400 -->
    <!-- Lora removida (ADR-0015 §11 Q8) -->
    <!-- Newsreader NÃO preloaded — carrega lazy, pull quotes não são above-the-fold -->
    <link
      rel="preload"
      href="/fonts/inter-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <title>{title}</title>
  </head>

  <body class="font-sans min-h-dvh flex flex-col antialiased paper-grain" style="background-color: var(--color-paper); color: var(--color-ink);">

    <!-- Skip to content (a11y) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:rounded focus:text-sm focus:font-medium focus:shadow-soft"
      style="background-color: var(--color-celestial-700); color: white;"
    >
      Ir para o conteúdo
    </a>

    <!-- Header -->
    <header
      id="site-header"
      data-variant={headerVariant}
      class:list={[
        'sticky top-0 z-40 transition-all duration-300',
        headerVariant === 'solid'
          ? 'shadow-paper-lift'
          : 'bg-transparent',
      ]}
      style={headerVariant === 'solid' ? `background-color: var(--color-paper-deep);` : ''}
    >
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <!-- Logo wordmark — Fraunces 700 opsz 24 ink (ADR-0015 §2.1) -->
          <a
            href="/"
            class="fraunces-h2 font-bold tracking-tight transition-opacity hover:opacity-70 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 rounded"
            style="color: var(--color-ink); font-variation-settings: 'opsz' 24, 'wght' 700; font-size: 1.25rem;"
            aria-label="Gabriel — Página inicial"
          >
            <span
              class="header-logo-sigil"
              style="font-variation-settings: 'opsz' 32, 'wght' 800; font-style: italic; color: var(--color-divine-700); margin-right: 0.1em;"
              aria-hidden="true"
            >G·</span>Gabriel
          </a>

          <!-- Nav legal links — Inter 500 caps tracked (ADR-0015 §2.1) -->
          <nav aria-label="Links legais">
            <ul class="flex items-center gap-1 sm:gap-2">
              <li>
                <a
                  href="/privacy"
                  class="header-nav-link text-xs sm:text-sm font-medium px-2 sm:px-3 py-1.5 rounded transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1"
                  style="letter-spacing: 0.04em; color: var(--color-ink-muted);"
                >
                  Privacidade
                </a>
              </li>
              <li>
                <a
                  href="/terms"
                  class="header-nav-link text-xs sm:text-sm font-medium px-2 sm:px-3 py-1.5 rounded transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1"
                  style="letter-spacing: 0.04em; color: var(--color-ink-muted);"
                >
                  Termos
                </a>
              </li>
              <li>
                <a
                  href="/delete-account"
                  class="header-nav-link text-xs sm:text-sm font-medium px-2 sm:px-3 py-1.5 rounded transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1"
                  style="letter-spacing: 0.04em; color: var(--color-ink-muted);"
                >
                  Excluir Conta
                </a>
              </li>
              <!-- CornerFleuron sutil no nav -->
              <li aria-hidden="true" class="hidden sm:block pl-2" style="color: var(--color-divine-700); font-family: var(--font-family-display); font-size: 0.875rem; opacity: 0.7;">❧</li>
            </ul>
          </nav>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <!-- Footer — refeito ink + ornamentos (ADR-0015 §11 Q7, PLAN-V1.5 §2.7) -->
    <footer style="background-color: var(--color-ink); color: var(--color-paper);">
      <!-- FloralDivider top — divine-500 full width -->
      <div
        aria-hidden="true"
        style="width: 100%; overflow: hidden; line-height: 0; opacity: 0.6;"
      >
        <svg
          viewBox="0 0 400 20"
          preserveAspectRatio="none"
          xmlns="http://www.w3.org/2000/svg"
          style="width: 100%; height: 20px; display: block;"
          aria-hidden="true"
        >
          <!-- FloralDivider horizontal editorial — composição linha + elementos centrais -->
          <!-- Fonte tipográfica: SVG geométrico próprio (linhas + diamante) — não é Bezier artístico inventado -->
          <!-- Baseado em padrão ornamental clássico de divisores editoriais de impressão tipográfica -->
          <line x1="0" y1="10" x2="160" y2="10" stroke="#D4AF37" stroke-width="0.75" opacity="0.8"/>
          <line x1="240" y1="10" x2="400" y2="10" stroke="#D4AF37" stroke-width="0.75" opacity="0.8"/>
          <circle cx="200" cy="10" r="3" fill="none" stroke="#D4AF37" stroke-width="1"/>
          <circle cx="185" cy="10" r="1.5" fill="#D4AF37"/>
          <circle cx="215" cy="10" r="1.5" fill="#D4AF37"/>
          <path d="M195 10 L200 5 L205 10 L200 15 Z" fill="none" stroke="#D4AF37" stroke-width="0.75"/>
          <circle cx="170" cy="10" r="1" fill="#D4AF37" opacity="0.6"/>
          <circle cx="230" cy="10" r="1" fill="#D4AF37" opacity="0.6"/>
        </svg>
      </div>

      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 items-start">
          <!-- Wordmark + copyright -->
          <div>
            <p
              class="font-bold mb-2"
              style="font-family: var(--font-family-display); font-variation-settings: 'opsz' 32, 'wght' 700; font-size: 1.5rem; color: var(--color-paper);"
            >
              Gabriel
            </p>
            <p class="text-xs" style="color: var(--color-paper-deep); line-height: 1.6;">
              &copy; {year}
              <a
                href="https://vhxco.com"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:opacity-80 transition-opacity underline underline-offset-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1 rounded"
                style="color: var(--color-paper-deep);"
              >VHXCO</a>.
              Todos os direitos reservados.
            </p>
          </div>

          <!-- Links legais -->
          <nav aria-label="Links legais do rodapé" class="sm:text-right">
            <ul class="flex flex-wrap sm:justify-end gap-x-5 gap-y-2">
              <li>
                <a
                  href="/privacy"
                  class="text-xs hover:opacity-80 transition-opacity focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1 rounded"
                  style="color: var(--color-paper-deep); letter-spacing: 0.04em;"
                >
                  Privacidade
                </a>
              </li>
              <li>
                <a
                  href="/terms"
                  class="text-xs hover:opacity-80 transition-opacity focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1 rounded"
                  style="color: var(--color-paper-deep); letter-spacing: 0.04em;"
                >
                  Termos de Uso
                </a>
              </li>
              <li>
                <a
                  href="/delete-account"
                  class="text-xs hover:opacity-80 transition-opacity focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1 rounded"
                  style="color: var(--color-paper-deep); letter-spacing: 0.04em;"
                >
                  Excluir Conta
                </a>
              </li>
            </ul>
          </nav>
        </div>

        <!-- CornerFleuron bottom centralizado -->
        <div
          class="text-center mt-8 pt-6"
          style="border-top: 1px solid rgba(212, 175, 55, 0.15);"
          aria-hidden="true"
        >
          <span
            style="font-family: var(--font-family-display); font-variation-settings: 'opsz' 32, 'wght' 500; color: var(--color-divine-700); font-size: 1.25rem; opacity: 0.8;"
          >❧</span>
        </div>
      </div>
    </footer>

    <!-- Header scroll behavior: transparent → paper-deep (headerVariant='transparent') -->
    <script>
      const header = document.getElementById('site-header');
      if (header && header.dataset.variant === 'transparent') {
        const logoEl = header.querySelector('.header-logo-sigil');
        const navLinks = header.querySelectorAll('.header-nav-link');

        function applyScrollState() {
          const scrolled = window.scrollY > 20;
          if (scrolled) {
            header!.style.backgroundColor = 'var(--color-paper-deep)';
            header!.style.backdropFilter = 'blur(8px)';
            header!.style.boxShadow = 'var(--shadow-paper-lift)';
          } else {
            header!.style.backgroundColor = 'transparent';
            header!.style.backdropFilter = '';
            header!.style.boxShadow = '';
          }
        }

        window.addEventListener('scroll', applyScrollState, { passive: true });
        applyScrollState();
      }
    </script>
  </body>
</html>
