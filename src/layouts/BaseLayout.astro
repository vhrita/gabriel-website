---
import '../styles/global.css';
import StoreBadge from '../components/ui/StoreBadge.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  pathname?: string;
  type?: 'website' | 'article';
  headerVariant?: 'transparent' | 'solid';
  bodyTheme?: 'paper' | 'dark' | 'light';
}

const {
  title,
  description = 'Gabriel — Bíblia e Devocional. Dez minutos com Deus, todo dia, no seu ritmo.',
  image = '/og-image.png',
  pathname,
  type = 'website',
  headerVariant = 'solid',
  bodyTheme = 'paper',
} = Astro.props;

const resolvedPathname = pathname ?? Astro.url.pathname;
const canonicalURL = new URL(resolvedPathname, Astro.site ?? 'https://gabriel.vhxco.com');
const ogImageURL = new URL(image, Astro.site ?? 'https://gabriel.vhxco.com');
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Theme color — adapts to bodyTheme -->
    <meta name="theme-color" content={bodyTheme === 'dark' ? '#0E1D33' : bodyTheme === 'light' ? '#FFFFFF' : '#FAF7F0'} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Gabriel" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Fontes: @fontsource (global.css) com font-display: swap, bundled em /_astro por hash.
         Preload estático removido — apontava p/ caminho não-bundled e nunca casava (warning). -->

    <!-- Favicons -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="icon" href="/favicon.ico" />

    <title>{title}</title>
  </head>

  <body
    class:list={[
      'font-sans min-h-dvh flex flex-col antialiased',
      bodyTheme === 'paper' && 'paper-grain',
    ]}
    style={bodyTheme === 'dark'
      ? 'background-color: var(--color-bg-dark-base); color: var(--color-text-on-dark);'
      : bodyTheme === 'light'
      ? 'background-color: var(--color-bg-base); color: var(--color-text-strong);'
      : 'background-color: var(--color-paper); color: var(--color-ink);'}
  >

    <!-- Skip to content (a11y) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:rounded focus:text-sm focus:font-medium focus:shadow-soft"
      style="background-color: var(--color-celestial-700); color: white;"
    >
      Ir para o conteúdo
    </a>

    <!-- Header
         polish-v2:
         - Solid: paper bg, no shadow (clean, no floating "white strip")
         - Transparent (home): starts transparent, scrolled → paper 85% opacity + blur(12px) + hairline border
         - Height reduced to h-12 (lighter visual weight)
         - App icon replaces G· sigil
    -->
    <header
      id="site-header"
      data-variant={headerVariant}
      data-body-theme={bodyTheme}
      class:list={[
        'sticky top-0 z-50 transition-all duration-300',
        headerVariant === 'solid'
          ? 'header--solid'
          : 'header--transparent',
      ]}
      style={headerVariant === 'solid'
        ? (bodyTheme === 'dark'
            ? 'background-color: var(--color-bg-dark-base); border-bottom: 1px solid var(--color-divider-on-dark);'
            : bodyTheme === 'light'
            ? 'background-color: var(--color-bg-base); border-bottom: 1px solid var(--color-divider-soft);'
            : 'background-color: var(--color-paper); border-bottom: 1px solid rgba(26, 24, 20, 0.06);')
        : ''}
    >
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-12">
          <!-- Logo: app icon + wordmark -->
          <a
            href="/"
            class="header-logo flex items-center gap-2 transition-opacity hover:opacity-70 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 rounded"
            aria-label="Gabriel — Página inicial"
          >
            <img
              src="/app-icon.png"
              alt=""
              width="28"
              height="28"
              class="header-logo-icon"
              aria-hidden="true"
              style="border-radius: 6px; display: inline-block; vertical-align: middle; flex-shrink: 0;"
            />
            <span
              style={`font-family: var(--font-family-display); font-variation-settings: 'opsz' 24, 'wght' 700; font-size: 1.25rem; color: ${bodyTheme === 'dark' ? 'var(--color-text-on-dark)' : bodyTheme === 'light' ? 'var(--color-text-strong)' : 'var(--color-ink)'}; letter-spacing: -0.02em; -webkit-font-smoothing: antialiased;`}
            >Gabriel</span>
          </a>

          <!-- Nav legal links — Inter 500 caps tracked -->
          <nav aria-label="Links legais">
            <ul class="flex items-center gap-1 sm:gap-2">
              <li>
                <a
                  href="/privacy"
                  class="header-nav-link text-xs sm:text-sm font-medium px-2 sm:px-3 py-1.5 rounded transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1"
                  style={`letter-spacing: 0.04em; color: ${bodyTheme === 'dark' ? 'var(--color-text-on-dark-muted)' : bodyTheme === 'light' ? 'var(--color-text-muted)' : 'var(--color-ink-muted)'};`}
                >
                  Privacidade
                </a>
              </li>
              <li>
                <a
                  href="/terms"
                  class="header-nav-link text-xs sm:text-sm font-medium px-2 sm:px-3 py-1.5 rounded transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1"
                  style={`letter-spacing: 0.04em; color: ${bodyTheme === 'dark' ? 'var(--color-text-on-dark-muted)' : bodyTheme === 'light' ? 'var(--color-text-muted)' : 'var(--color-ink-muted)'};`}
                >
                  Termos
                </a>
              </li>
              <li class="hidden sm:block">
                <a
                  href="/delete-account"
                  class="header-nav-link text-xs sm:text-sm font-medium px-2 sm:px-3 py-1.5 rounded transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-divine-500 focus-visible:ring-offset-1"
                  style={`letter-spacing: 0.04em; color: ${bodyTheme === 'dark' ? 'var(--color-text-on-dark-muted)' : bodyTheme === 'light' ? 'var(--color-text-muted)' : 'var(--color-ink-muted)'}; white-space: nowrap;`}
                >
                  Excluir Conta
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <!-- Footer v4 — Dark navy anchor. bg navy (celestial-900) sobre home light. -->
    <footer style="background-color: var(--color-bg-dark-base); color: var(--color-text-on-dark);">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
        <div class="footer-grid">

          <!-- Wordmark + tagline -->
          <div class="footer-brand">
            <p
              style="font-family: var(--font-family-display); font-variation-settings: 'opsz' 48, 'wght' 700; font-size: 1.75rem; color: var(--color-text-on-dark); margin: 0 0 0.5rem; letter-spacing: -0.025em; -webkit-font-smoothing: antialiased;"
            >
              Gabriel
            </p>
            <p
              style="font-family: var(--font-family-serif); font-variation-settings: 'opsz' 14; font-style: italic; font-size: 0.875rem; color: var(--color-text-on-dark-muted); margin: 0; line-height: 1.5;"
            >
              Bíblia e devocional, todos os dias.
            </p>
          </div>

          <!-- Links coluna App — StoreBadges small -->
          <nav aria-label="Links do app" class="footer-col">
            <p
              style="font-family: var(--font-family-sans); font-size: 0.6875rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(250, 247, 240, 0.55); margin: 0 0 0.875rem;"
            >
              App
            </p>
            <div style="display: flex; flex-direction: column; gap: 0.625rem; align-items: flex-start;">
              <StoreBadge
                variant="google-play"
                href="https://play.google.com/store/apps/details?id=com.gabriel.biblia"
                size="sm"
              />
              <!-- iOS ainda não lançou — rótulo honesto (consistente com hero/CTA),
                   estilizado p/ o footer dark em vez da badge oficial cinza. -->
              <span
                role="img"
                aria-label="App para iOS — em breve"
                style="display: inline-flex; align-items: center; gap: 0.4375rem; height: 36px; padding-inline: 0.75rem; border: 1px solid rgba(250, 247, 240, 0.18); border-radius: 8px; font-family: var(--font-family-sans); font-size: 0.8125rem; font-weight: 500; color: rgba(250, 247, 240, 0.65); letter-spacing: 0.01em;"
              >
                <svg width="13" height="16" viewBox="0 0 384 512" fill="currentColor" aria-hidden="true">
                  <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/>
                </svg>
                iOS em breve
              </span>
            </div>
          </nav>

          <!-- Links coluna Legal -->
          <nav aria-label="Links legais do rodapé" class="footer-col">
            <p
              style="font-family: var(--font-family-sans); font-size: 0.6875rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(250, 247, 240, 0.55); margin: 0 0 0.75rem;"
            >
              Legal
            </p>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
              <li>
                <a
                  href="/privacy"
                  style="font-family: var(--font-family-sans); font-size: 0.8125rem; font-weight: 500; color: rgba(250, 247, 240, 0.75); text-decoration: none; letter-spacing: 0.02em; transition: color 200ms;"
                  class="footer-link"
                >
                  Privacidade
                </a>
              </li>
              <li>
                <a
                  href="/terms"
                  style="font-family: var(--font-family-sans); font-size: 0.8125rem; font-weight: 500; color: rgba(250, 247, 240, 0.75); text-decoration: none; letter-spacing: 0.02em; transition: color 200ms;"
                  class="footer-link"
                >
                  Termos
                </a>
              </li>
              <li>
                <a
                  href="/delete-account"
                  style="font-family: var(--font-family-sans); font-size: 0.8125rem; font-weight: 500; color: rgba(250, 247, 240, 0.75); text-decoration: none; letter-spacing: 0.02em; transition: color 200ms;"
                  class="footer-link"
                >
                  Excluir Conta
                </a>
              </li>
            </ul>
          </nav>

        </div>

        <!-- Bottom bar -->
        <div
          style="border-top: 1px solid rgba(170, 141, 44, 0.2); margin-top: 3rem; padding-top: 1.25rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;"
        >
          <p
            style="font-family: var(--font-family-sans); font-size: 0.6875rem; color: rgba(250, 247, 240, 0.55); margin: 0; letter-spacing: 0.02em;"
          >
            &copy; {year} Gabriel · CNPJ 62.874.893/0001-51
          </p>
          <!-- Assinatura discreta da software house. Linkada pro site da VHXCO
               (no ar). X ciano sobre o navy (PNG já transparente). Hover sutil. -->
          <a
            href="https://vhxco.com"
            target="_blank"
            rel="noopener"
            class="footer-vhxco"
            style="display: inline-flex; align-items: center; gap: 0.4375rem; font-family: var(--font-family-sans); font-size: 0.6875rem; color: rgba(250, 247, 240, 0.85); letter-spacing: 0.02em; text-decoration: none; transition: opacity 200ms;"
          >
            <img
              src="/vhxco-mark.png"
              alt="VHXCO"
              width="20"
              height="20"
              style="height: 20px; width: auto; display: block; flex-shrink: 0;"
            />
            Uma criação VHXCO
          </a>
        </div>
      </div>

      <style>
        .footer-grid {
          display: grid;
          grid-template-columns: 1fr;
          gap: 2.5rem;
        }
        @media (min-width: 640px) {
          .footer-grid {
            grid-template-columns: 1fr 1fr 1fr;
            gap: 2rem;
          }
        }
        .footer-link:hover {
          color: rgba(250, 247, 240, 0.95) !important;
        }
        .footer-vhxco:hover {
          opacity: 0.7;
        }
      </style>
    </footer>

    <!-- Global reveal-on-enter: bidirectional IntersectionObserver for [data-reveal] -->
    <script src="../scripts/reveal-on-enter.ts"></script>

    <!-- Header scroll behavior:
         transparent (home): starts clear, scrolls to paper 85% + blur + hairline border
         solid (legal pages): always paper bg + hairline, no transitions needed
    -->
    <script>
      const header = document.getElementById('site-header');
      if (header && header.dataset.variant === 'transparent') {
        const isDark = header.dataset.bodyTheme === 'dark';
        const isLight = header.dataset.bodyTheme === 'light';
        const bgScrolled = isDark
          ? 'rgba(14, 29, 51, 0.85)'
          : isLight
          ? 'rgba(255, 255, 255, 0.85)'
          : 'rgba(250, 247, 240, 0.85)';
        const borderScrolled = isDark
          ? '1px solid rgba(250, 247, 240, 0.10)'
          : isLight
          ? '1px solid rgba(30, 58, 95, 0.06)'
          : '1px solid rgba(26, 24, 20, 0.06)';

        function applyScrollState() {
          const scrolled = window.scrollY > 20;
          const style = header!.style as CSSStyleDeclaration & { webkitBackdropFilter: string };
          if (scrolled) {
            style.backgroundColor = bgScrolled;
            style.backdropFilter = 'blur(12px)';
            style.webkitBackdropFilter = 'blur(12px)';
            style.borderBottom = borderScrolled;
            style.boxShadow = 'none';
          } else {
            style.backgroundColor = 'transparent';
            style.backdropFilter = '';
            style.webkitBackdropFilter = '';
            style.borderBottom = '';
            style.boxShadow = '';
          }
        }

        window.addEventListener('scroll', applyScrollState, { passive: true });
        applyScrollState();
      }
    </script>
  </body>
</html>
