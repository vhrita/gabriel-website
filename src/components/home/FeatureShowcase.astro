---
/**
 * FeatureShowcase.astro — Horizontal scroll-snap showcase for tablet/desktop ≥768px
 *
 * Mobile (<768px): children stack vertically (default flow, no changes).
 * Tablet/Desktop (≥768px): children displayed in a horizontal scroll-snap row,
 * Play Store carousel style — 2-3 cards visible, peek on next card.
 *
 * Uses CSS scroll-snap (no JS, no extra libs).
 * Panel overrides injected via global.css .feature-showcase context selectors.
 */
---

<section class="feature-showcase" aria-label="Funcionalidades do app">
  <!-- Scroll hint chevron — fades out on first scroll via JS -->
  <button class="showcase-scroll-hint" aria-hidden="true" tabindex="-1">
    <!-- lucide:chevron-right, MIT license, https://lucide.dev -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="28"
      height="28"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m9 18 6-6-6-6"/>
    </svg>
  </button>

  <div class="showcase-track">
    <slot />
  </div>
</section>

<script>
  // Fade out the scroll hint once user has scrolled
  const showcase = document.querySelector('.feature-showcase');
  const hint = showcase?.querySelector('.showcase-scroll-hint');
  const track = showcase?.querySelector('.showcase-track');

  if (track && hint) {
    const onScroll = () => {
      if (track.scrollLeft > 40) {
        (hint as HTMLElement).style.opacity = '0';
        (hint as HTMLElement).style.pointerEvents = 'none';
        track.removeEventListener('scroll', onScroll);
      }
    };
    track.addEventListener('scroll', onScroll, { passive: true });
  }
</script>

<style>
  .feature-showcase {
    position: relative;
  }

  .showcase-track {
    /* Mobile: normal block stacking (no overrides needed — Panel default) */
    display: block;
  }

  /* Scroll hint — hidden on mobile */
  .showcase-scroll-hint {
    display: none;
  }

  /* ===== Tablet/Desktop ≥768px: horizontal scroll-snap carousel ===== */
  @media (min-width: 768px) {
    .feature-showcase {
      /* Navy background for the whole row — unifies panels */
      background: linear-gradient(180deg, #12243e 0%, #0e1d33 100%);
      overflow: hidden;
    }

    .showcase-track {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      gap: clamp(1rem, 2vw, 2rem);
      /* Lateral padding: breathing room so first/last card doesn't hug the edge */
      padding: 4rem clamp(2rem, 6vw, 6rem);
      /* Hide scrollbar cross-browser */
      scrollbar-width: none; /* Firefox */
      -ms-overflow-style: none; /* IE/Edge legacy */
    }

    .showcase-track::-webkit-scrollbar {
      display: none; /* Chrome/Safari */
    }
  }

  /* Scroll hint — tablet/desktop only */
  @media (min-width: 768px) {
    .showcase-scroll-hint {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      right: 1.25rem;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: rgba(14, 29, 51, 0.7);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(212, 175, 55, 0.25);
      color: rgba(250, 247, 240, 0.8);
      cursor: default;
      pointer-events: none;
      transition: opacity 400ms ease;
      /* Gentle pulse to attract attention */
      animation: hint-pulse 2.5s ease-in-out 1.5s 3 forwards;
    }
  }

  @keyframes hint-pulse {
    0%, 100% { opacity: 1; transform: translateY(-50%) translateX(0); }
    50% { opacity: 0.6; transform: translateY(-50%) translateX(-4px); }
  }
</style>
