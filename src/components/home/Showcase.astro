---
/**
 * Showcase.astro
 * Seção showcase — composição assimétrica 1.4fr/1fr desktop.
 * ADR-0015 §11 + PLAN-V1.5 §2.6.
 *
 * Estrutura:
 *   - bg: paper-deep (não heavenly)
 *   - SectionKickerBanner "IV — COMECE HOJE"
 *   - Desktop: mockups à esquerda (composição 3 phones) + copy+CTAs à direita
 *   - Mobile: stack vertical, mockups primeiro
 *   - H2: "Gratuito pra começar." Fraunces 600 opsz 72
 *   - Body: "Sem anúncios. Sem tracking. Sua jornada, sua privacidade."
 *   - CTAs: Google Play primary + App Store disabled
 *   - Mockup central: parallax scroll-driven (mantido do v1)
 *   - CornerFleuron bottom
 *
 * Mockups: placeholder SVG (Vitor entregará screenshots reais pra substituir)
 * Cores phone frame: trocadas para ink (era celestial-700) — consistência paper-ink
 */

import SectionKickerBanner from '../ornaments/SectionKickerBanner.astro';
import CornerFleuron from '../ornaments/CornerFleuron.astro';
import Button from '../ui/Button.astro';
---

<section
  style="
    background-color: var(--color-paper-deep);
    padding: clamp(5rem, 8vw, 8rem) 0 clamp(4rem, 6vw, 6rem);
  "
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Kicker IV -->
    <div style="margin-bottom: 3rem;">
      <SectionKickerBanner
        numeral="IV"
        label="Comece Hoje"
        tone="on-paper"
        showDivider
      />
    </div>

    <!-- Grid assimétrico: 1.4fr/1fr desktop, stack mobile -->
    <div
      class="showcase-grid"
      style="
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        align-items: center;
      "
    >

      <!-- COLUNA ESQUERDA: composição de 3 mockups -->
      <div class="showcase-mockups">
        <div
          style="
            display: flex;
            align-items: flex-end;
            justify-content: center;
            gap: 1rem;
            position: relative;
          "
        >

          <!-- Mockup esquerdo — offset +8px Y (levemente mais baixo) -->
          <div
            data-reveal
            class="reveal-on-enter"
            style="--delay: 0ms; transform: translateY(8px);"
          >
            <div class="phone-frame" style="filter: drop-shadow(0 4px 16px rgba(26, 24, 20, 0.10));">
              <svg
                width="140"
                height="248"
                viewBox="0 0 140 248"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-label="Screenshot do app Gabriel (placeholder)"
                role="img"
              >
                <rect x="2" y="2" width="136" height="244" rx="20" stroke="#1A1814" stroke-width="2.5" fill="#FAF7F0" />
                <rect x="50" y="9" width="40" height="7" rx="3.5" fill="#6E6759" opacity="0.4"/>
                <rect x="10" y="27" width="120" height="202" rx="8" fill="#F2EDE0" />
                <text x="70" y="135" text-anchor="middle" font-size="10" fill="#6E6759" font-family="system-ui, sans-serif" opacity="0.7">screenshot</text>
                <rect x="55" y="235" width="30" height="3.5" rx="1.75" fill="#6E6759" opacity="0.4"/>
              </svg>
            </div>
          </div>

          <!-- Mockup central — maior, parallax scroll-driven, offset -8px Y -->
          <div
            data-reveal
            class="reveal-on-enter phone-frame-center"
            style="--delay: 80ms;"
          >
            <div class="phone-frame phone-frame--featured" style="filter: drop-shadow(0 8px 28px rgba(26, 24, 20, 0.15));">
              <svg
                width="170"
                height="300"
                viewBox="0 0 170 300"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-label="Screenshot principal do app Gabriel (placeholder)"
                role="img"
              >
                <!-- Frame externo — ink mais forte no central -->
                <rect x="2" y="2" width="166" height="296" rx="24" stroke="#1A1814" stroke-width="3" fill="#FAF7F0" />
                <rect x="62" y="10" width="46" height="8" rx="4" fill="#6E6759" opacity="0.35"/>
                <rect x="12" y="30" width="146" height="248" rx="10" fill="#F2EDE0" />
                <!-- Ornamento sutil no mockup — evoca manuscrito -->
                <text x="85" y="155" text-anchor="middle" font-size="11" fill="#6E6759" font-family="system-ui, sans-serif" opacity="0.6">screenshot</text>
                <!-- Indicador de status bar sutil -->
                <rect x="12" y="30" width="146" height="20" rx="10" fill="#EBE6D9" opacity="0.8"/>
                <rect x="68" y="284" width="34" height="4.5" rx="2.25" fill="#6E6759" opacity="0.35"/>
              </svg>
            </div>
          </div>

          <!-- Mockup direito — offset +8px Y -->
          <div
            data-reveal
            class="reveal-on-enter"
            style="--delay: 160ms; transform: translateY(8px);"
          >
            <div class="phone-frame" style="filter: drop-shadow(0 4px 16px rgba(26, 24, 20, 0.10));">
              <svg
                width="140"
                height="248"
                viewBox="0 0 140 248"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-label="Screenshot do app Gabriel (placeholder)"
                role="img"
              >
                <rect x="2" y="2" width="136" height="244" rx="20" stroke="#1A1814" stroke-width="2.5" fill="#FAF7F0" />
                <rect x="50" y="9" width="40" height="7" rx="3.5" fill="#6E6759" opacity="0.4"/>
                <rect x="10" y="27" width="120" height="202" rx="8" fill="#F2EDE0" />
                <text x="70" y="135" text-anchor="middle" font-size="10" fill="#6E6759" font-family="system-ui, sans-serif" opacity="0.7">screenshot</text>
                <rect x="55" y="235" width="30" height="3.5" rx="1.75" fill="#6E6759" opacity="0.4"/>
              </svg>
            </div>
          </div>

        </div>
      </div>

      <!-- COLUNA DIREITA: copy + CTAs -->
      <div
        data-reveal
        class="reveal-on-enter showcase-copy"
        style="--delay: 200ms;"
      >

        <!-- H2 — "Gratuito pra começar." -->
        <h2
          style="
            font-family: var(--font-family-display);
            font-variation-settings: 'opsz' 72, 'wght' 600;
            font-size: clamp(2.5rem, 5vw, 4rem);
            line-height: 1.02;
            letter-spacing: -0.025em;
            color: var(--color-ink);
            margin: 0 0 1rem;
            -webkit-font-smoothing: antialiased;
          "
        >
          Gratuito pra começar.
        </h2>

        <!-- Body — diferencial real -->
        <p
          style="
            font-family: var(--font-family-serif);
            font-variation-settings: 'opsz' 16;
            font-weight: 400;
            font-size: clamp(1rem, 1.3vw, 1.125rem);
            line-height: 1.7;
            color: var(--color-ink-soft);
            margin: 0 0 2rem;
            max-width: 40ch;
          "
        >
          Sem anúncios. Sem tracking. Sua jornada, sua privacidade.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4">
          <Button
            variant="primary"
            href="https://play.google.com/store/apps/details?id=com.gabriel.biblia"
            external
          >
            Baixar no Google Play
          </Button>
          <Button variant="disabled">
            App Store · Em breve
          </Button>
        </div>
      </div>

    </div><!-- /showcase-grid -->

    <!-- CornerFleuron bottom -->
    <div style="text-align: center; margin-top: 3rem;" aria-hidden="true">
      <CornerFleuron size="md" tone="muted" />
    </div>

  </div>
</section>

<style>
  /* Grid assimétrico — desktop: 1.4fr 1fr */
  @media (min-width: 1024px) {
    .showcase-grid {
      grid-template-columns: 1.4fr 1fr !important;
      gap: 3rem !important;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .showcase-grid {
      grid-template-columns: 1fr 1fr !important;
    }
  }

  /* Reveal base */
  [data-reveal],
  .reveal-on-enter {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 600ms ease-out,
      transform 600ms ease-out;
    transition-delay: var(--delay, 0ms);
  }

  [data-reveal].is-visible,
  .reveal-on-enter.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    .reveal-on-enter {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* Phone frame base */
  .phone-frame {
    display: inline-flex;
    transition: filter 300ms ease;
  }

  .phone-frame:hover {
    filter: drop-shadow(0 8px 24px rgba(26, 24, 20, 0.18)) !important;
  }

  /* Parallax scroll-driven para o mockup central — CSS puro */
  @supports (animation-timeline: scroll()) {
    @media (prefers-reduced-motion: no-preference) {
      .phone-frame-center {
        animation: parallax-float linear both;
        animation-timeline: scroll(root block);
        animation-range: 0% 60%;
      }

      @keyframes parallax-float {
        from { --parallax-offset: 0px; }
        to { --parallax-offset: -40px; }
      }

      .phone-frame-center.is-visible {
        transform: translateY(var(--parallax-offset, 0px));
        transition: none;
      }
    }
  }
</style>

<script>
  import '../../scripts/reveal-on-enter.ts';
</script>
