---
/**
 * HeroSection.astro — v3
 *
 * Hero editorial dark: 2-col grid em desktop (text esq + PhoneFrame dir),
 * stack em mobile (text acima, phone abaixo).
 *
 * Block source inspirado em Preline "Split Hero with Product Mockup":
 * https://preline.co/blocks/marketing/hero-sections/#split-hero-with-product-mockup
 */

import StoreBadge from '../ui/StoreBadge.astro';
import PhoneFrame from '../mockups/PhoneFrame.astro';
---

<section
  class="hero-section"
  aria-label="Apresentação do Gabriel"
>
  <div class="hero-inner">

    <!-- Text column -->
    <div class="hero-text">

      <!-- Eyebrow -->
      <p class="hero-eyebrow" aria-hidden="true">g a b r i e l</p>

      <!-- H1 -->
      <h1 class="hero-h1 fraunces-wordmark">
        <span>Sua jornada</span>
        <em>espiritual</em><span>,</span>
        <br/>
        <span>todos os dias.</span>
      </h1>

      <!-- Lead -->
      <p class="hero-lead newsreader-display">
        Devocional curto, Bíblia que cresce com você e um lugar
        pra parar — no seu ritmo, sem culpa.
      </p>

      <!-- Store badges -->
      <div class="hero-badges" role="group" aria-label="Baixar o app">
        <StoreBadge
          variant="google-play"
          href="https://play.google.com/store/apps/details?id=com.gabriel.biblia"
          size="md"
        />
        <StoreBadge
          variant="app-store"
          disabled
          size="md"
        />
      </div>

      <!-- Hint -->
      <p class="hero-hint">iOS em breve.</p>

    </div>

    <!-- Phone column -->
    <div class="hero-phone" aria-hidden="true">
      <PhoneFrame
        screen="devocional"
        alt="Tela de devocional do app Gabriel"
        size="lg"
        priority={true}
      />
    </div>

  </div>
</section>

<style>
  .hero-section {
    position: relative;
    background: var(--color-bg-dark-base);
    padding-block: clamp(5rem, 12vw, 9rem);
    overflow: hidden;
  }

  .hero-inner {
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 6vw, 4rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(3rem, 6vw, 5rem);
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr auto;
      gap: clamp(3rem, 6vw, 6rem);
    }
  }

  /* Eyebrow */
  .hero-eyebrow {
    font-family: var(--font-family-sans);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--color-accent-gold);
    margin: 0 0 1.5rem;
    opacity: 0.85;
  }

  /* H1 */
  .hero-h1 {
    font-size: clamp(2.75rem, 8vw, 5.5rem);
    line-height: 0.94;
    letter-spacing: -0.03em;
    color: var(--color-text-on-dark);
    margin: 0 0 1.75rem;
    -webkit-font-smoothing: antialiased;
  }

  .hero-h1 em {
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'wght' 800, 'SOFT' 100, 'WONK' 1;
    color: var(--color-text-on-dark);
  }

  /* Lead */
  .hero-lead {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    line-height: 1.6;
    color: var(--color-text-on-dark-muted);
    margin: 0 0 2.25rem;
    max-width: 36ch;
    font-style: italic;
    font-variation-settings: 'opsz' 36;
  }

  /* Badges */
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    align-items: center;
    margin-bottom: 0.875rem;
  }

  /* Hint */
  .hero-hint {
    font-family: var(--font-family-sans);
    font-size: 0.8125rem;
    font-style: italic;
    color: var(--color-text-on-dark-faint);
    margin: 0;
  }

  /* Phone column */
  .hero-phone {
    display: flex;
    justify-content: center;
    align-items: center;
    order: -1; /* mobile: phone acima do texto */
  }

  @media (min-width: 768px) {
    .hero-phone {
      order: 0; /* desktop: phone à direita */
      justify-content: flex-end;
    }
  }
</style>
