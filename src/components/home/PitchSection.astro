---
/**
 * PitchSection.astro
 * Seção de pitch editorial — bg celestial-700, paper text, kicker romano.
 * ADR-0015 §11 Q1 (copy poético acolhedor) + PLAN-V1.5 §2.3.
 *
 * Estrutura:
 *   - bg celestial-700 (mantido para contraste forte com paper do Hero)
 *   - SectionKickerBanner "II — UM SANTUÁRIO NO SEU BOLSO" on-ink
 *   - H1 Fraunces 600 opsz 72 paper, clamp(2.5rem,6vw,4.5rem), max-w ~24ch
 *   - Tagline italic Fraunces 500 opsz 48 divine-300: "Tudo isso, todos os dias."
 *   - CornerFleuron divine-500 bottom
 *   - rhythm: py-24 md:py-32 lg:py-40 (mais generoso que Hero — varia ritmo)
 */

import SectionKickerBanner from '../ornaments/SectionKickerBanner.astro';
import CornerFleuron from '../ornaments/CornerFleuron.astro';
---

<section
  style="
    background-color: var(--color-celestial-700);
    padding: clamp(5rem, 8vw, 8rem) 0;
  "
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      data-reveal
      class="reveal-on-enter"
    >

      <!-- Kicker II -->
      <SectionKickerBanner
        numeral="II"
        label="Um Santuário no Seu Bolso"
        tone="on-ink"
        showDivider
      />

      <!-- H1 principal — cópia poética (ADR-0015 §11 Q1) -->
      <h2
        style="
          font-family: var(--font-family-display);
          font-variation-settings: 'opsz' 72, 'wght' 600;
          font-size: clamp(2.5rem, 6vw, 4.5rem);
          line-height: 1.05;
          letter-spacing: -0.025em;
          color: var(--color-paper);
          margin: 0 0 2rem;
          max-width: 24ch;
          -webkit-font-smoothing: antialiased;
        "
      >
        Devocionais personalizados por IA. A Bíblia inteira em três idiomas. Um caminho de leitura que cresce contigo.
      </h2>

      <!-- Tagline italic — "Tudo isso, todos os dias." -->
      <p
        style="
          font-family: var(--font-family-display);
          font-variation-settings: 'opsz' 48, 'wght' 500;
          font-style: italic;
          font-size: clamp(1.5rem, 3vw, 2.25rem);
          line-height: 1.2;
          color: var(--color-divine-300);
          margin: 0 0 3rem;
          -webkit-font-smoothing: antialiased;
        "
      >
        Tudo isso, todos os dias.
      </p>

      <!-- CornerFleuron divine-500 -->
      <CornerFleuron size="md" tone="paper" />

    </div>
  </div>
</section>

<style>
  [data-reveal],
  .reveal-on-enter {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 600ms ease-out,
      transform 600ms ease-out;
  }

  [data-reveal].is-visible,
  .reveal-on-enter.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    .reveal-on-enter {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  import '../../scripts/reveal-on-enter.ts';
</script>
