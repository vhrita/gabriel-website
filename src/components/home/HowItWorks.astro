---
/**
 * HowItWorks.astro — v4 light (NOVA seção)
 *
 * 3 passos "Como funciona". Desktop: 3 colunas com numeral Fraunces gold-deep
 * + título + 1 frase. Mobile: stack vertical.
 * Background: bg-alt (slate-50) — contraste sutil com sections adjacentes.
 *
 * Block source: Preline "Steps with icons" adaptado (free)
 * https://preline.co/blocks/marketing/features-steps/
 * Ícones substituídos por numerais Fraunces gold-deep (consistência visual com FeatureRow).
 */
---

<section
  class="how-it-works"
  aria-label="Como o Gabriel funciona"
>
  <div class="how-inner">

    <!-- Header -->
    <div class="how-header">
      <p class="how-eyebrow" aria-hidden="true">c o m e c e</p>
      <h2 class="how-h2 fraunces-h1">Em menos de 1 minuto.</h2>
      <p class="how-sub newsreader-text">Sem formulários. Sem configuração obrigatória.</p>
    </div>

    <!-- Steps grid -->
    <div class="how-steps">

      <!-- Passo 01 -->
      <div class="how-step">
        <p class="how-step-num fraunces-numeral" aria-hidden="true">01</p>
        <h3 class="how-step-title fraunces-h3">Baixe e abra</h3>
        <p class="how-step-body newsreader-text">
          Em menos de 1 minuto. Sem cadastro pra começar.
        </p>
      </div>

      <!-- Passo 02 -->
      <div class="how-step">
        <p class="how-step-num fraunces-numeral" aria-hidden="true">02</p>
        <h3 class="how-step-title fraunces-h3">Conte o que importa</h3>
        <p class="how-step-body newsreader-text">
          Sua tradição, seus objetivos e (se quiser) uma Carta pra Deus.
        </p>
      </div>

      <!-- Passo 03 -->
      <div class="how-step">
        <p class="how-step-num fraunces-numeral" aria-hidden="true">03</p>
        <h3 class="how-step-title fraunces-h3">Receba todo dia</h3>
        <p class="how-step-body newsreader-text">
          Devocional, versículo e um amigo pronto pra conversar.
        </p>
      </div>

    </div>

  </div>
</section>

<style>
  .how-it-works {
    background: var(--color-bg-alt);
    padding-block: clamp(5rem, 10vw, 8rem);
  }

  .how-inner {
    max-width: 64rem;
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 6vw, 4rem);
  }

  /* Header */
  .how-header {
    text-align: center;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .how-eyebrow {
    font-family: var(--font-family-sans);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--color-accent-deep);
    margin: 0 0 1rem;
  }

  .how-h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--color-text-strong);
    margin: 0 0 0.75rem;
    -webkit-font-smoothing: antialiased;
  }

  .how-sub {
    font-size: clamp(1rem, 1.4vw, 1.125rem);
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
    font-style: italic;
    font-variation-settings: 'opsz' 18;
  }

  /* Steps */
  .how-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3rem);
  }

  @media (min-width: 768px) {
    .how-steps {
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(1.5rem, 3vw, 3rem);
    }
  }

  .how-step {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .how-step-num {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    color: var(--color-accent-deep);
    opacity: 0.75;
    margin: 0 0 0.25rem;
    -webkit-font-smoothing: antialiased;
  }

  .how-step-title {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-text-strong);
    margin: 0;
    -webkit-font-smoothing: antialiased;
  }

  .how-step-body {
    font-size: clamp(0.9375rem, 1.3vw, 1.0625rem);
    line-height: 1.65;
    color: var(--color-text-body);
    margin: 0;
    font-style: italic;
    font-variation-settings: 'opsz' 16;
  }
</style>
