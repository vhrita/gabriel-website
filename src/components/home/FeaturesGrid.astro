---
/**
 * FeaturesGrid.astro (renomeado conceitualmente: FeaturesList editorial)
 * Lista numerada editorial I-IV — diminuendo tipo manuscrito iluminado.
 * ADR-0015 §11 Q1 + PLAN-V1.5 §2.5.
 *
 * Estrutura por item:
 *   - Grid 2 colunas: [60-120px numeral | 1fr título + body]
 *   - Numeral romano: RomanNumeral Fraunces 800 italic opsz 96 divine-700
 *   - Título: Fraunces 600 opsz 32, ink, h3
 *   - Body: Newsreader 400 opsz 16 text, ink-soft
 *   - Thin divider 1px ink/10 entre items (não no último)
 *   - Reveal stagger 150ms por item
 *
 * Sem cards, sem ícones SVG — lista vertical editorial (ADR-0015 §2.5 decisão deliberada).
 * id="features" mantido — target do CTA secondary do Hero.
 */

import SectionKickerBanner from '../ornaments/SectionKickerBanner.astro';
import FloralDivider from '../ornaments/FloralDivider.astro';
import RomanNumeral from '../ornaments/RomanNumeral.astro';
import CornerFleuron from '../ornaments/CornerFleuron.astro';

const features = [
  {
    numeral: 'I' as const,
    title: 'Devocional diário, gerado por IA',
    copy: 'Cada dia, uma reflexão personalizada pela sua jornada espiritual.',
    delay: '0ms',
  },
  {
    numeral: 'II' as const,
    title: 'Bíblia + Jardim da Fé',
    copy: '66 livros da Bíblia em 3 idiomas. Veja seu progresso crescer como um jardim.',
    delay: '150ms',
  },
  {
    numeral: 'III' as const,
    title: 'Streak inteligente',
    copy: 'Construa constância no seu próprio ritmo — diário, 3x ou 5x na semana.',
    delay: '300ms',
  },
  {
    numeral: 'IV' as const,
    title: 'Gabriel Chat',
    copy: 'Tira dúvidas sobre fé e Bíblia com IA contextualizada pela sua religião.',
    delay: '450ms',
  },
] as const;
---

<section
  id="features"
  style="
    background-color: var(--color-paper);
    padding: clamp(5rem, 8vw, 8rem) 0;
  "
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Kicker III + FloralDivider -->
    <div style="margin-bottom: 3rem;">
      <SectionKickerBanner
        numeral="III"
        label="O que o Gabriel Entrega"
        tone="on-paper"
        showDivider
      />
      <!-- FloralDivider mais largo abaixo do kicker -->
      <div style="color: var(--color-divine-500); margin-top: 0.75rem;">
        <FloralDivider width="280px" />
      </div>
    </div>

    <!-- Lista de features I-IV -->
    <div class="features-list">
      {features.map((feature, index) => (
        <div
          data-reveal
          class="reveal-on-enter feature-item"
          style={`--delay: ${feature.delay}; ${index < features.length - 1 ? 'border-bottom: 1px solid rgba(26, 24, 20, 0.08); margin-bottom: 0; padding-bottom: 0;' : ''}`}
        >
          <!-- Grid 2 colunas: numeral | conteúdo -->
          <div
            style="
              display: grid;
              grid-template-columns: 80px 1fr;
              gap: 2rem;
              align-items: baseline;
              padding: clamp(2.5rem, 4vw, 4rem) 0;
            "
            class="feature-grid-inner"
          >
            <!-- Coluna numeral — Fraunces 800 italic opsz 96 divine-700 -->
            <div style="text-align: right; padding-top: 0.25rem;">
              <RomanNumeral numeral={feature.numeral} size="large" tone="divine" />
            </div>

            <!-- Coluna conteúdo -->
            <div>
              <!-- Título — Fraunces 600 opsz 32 -->
              <h3
                style="
                  font-family: var(--font-family-display);
                  font-variation-settings: 'opsz' 32, 'wght' 600;
                  font-size: clamp(1.375rem, 3.2vw, 2.25rem);
                  line-height: 1.15;
                  letter-spacing: -0.015em;
                  color: var(--color-ink);
                  margin: 0 0 0.75rem;
                  -webkit-font-smoothing: antialiased;
                "
              >
                {feature.title}
              </h3>

              <!-- Body — Newsreader 400 opsz text -->
              <p
                style="
                  font-family: var(--font-family-serif);
                  font-variation-settings: 'opsz' 16;
                  font-weight: 400;
                  font-size: clamp(1rem, 1.2vw, 1.125rem);
                  line-height: 1.7;
                  color: var(--color-ink-soft);
                  margin: 0;
                  max-width: 52ch;
                "
              >
                {feature.copy}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CornerFleuron bottom -->
    <div style="text-align: center; margin-top: 2rem;">
      <CornerFleuron size="md" tone="muted" />
    </div>

  </div>
</section>

<style>
  /* Reveal base com stagger via --delay */
  [data-reveal],
  .reveal-on-enter {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 600ms ease-out,
      transform 600ms ease-out;
    transition-delay: var(--delay, 0ms);
  }

  [data-reveal].is-visible,
  .reveal-on-enter.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    .reveal-on-enter {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* Numeral column responsivo */
  @media (max-width: 640px) {
    .feature-grid-inner {
      grid-template-columns: 56px 1fr !important;
      gap: 1.25rem !important;
    }
  }
</style>

<script>
  import '../../scripts/reveal-on-enter.ts';
</script>
