---
/**
 * HeroPanel.astro — Panel 1: "Abra seu coração e Gabriel te mostrará o caminho"
 *
 * First screen. Eager-loads PNG 1 (LCP candidate).
 * Only chrome: Store badges + "iOS em breve" hint.
 * H1 is visually hidden (sr-only) — copy is baked into the PNG.
 *
 * Bloco-fonte: Preline UI "Full-Bleed Image Hero with Text Overlay" (free)
 * https://preline.co/blocks/marketing/hero-sections/
 */

import Panel from './Panel.astro';
import StoreBadge from '../ui/StoreBadge.astro';
---

<Panel
  src="/screens/v2/1-1080.webp"
  src2x="/screens/v2/1-1620.webp"
  alt="Abra seu coração e Gabriel te mostrará o caminho — Fé guiada, Devocionais exclusivos e Bíblia. Tela do app Gabriel com ilustração de mãos rezando, livro e flores sakura."
  bgTone="navy-dark"
  eager={true}
  id="hero"
>
  <!-- H1 semântico oculto — copy real está baked na PNG -->
  <h1 class="sr-only">Gabriel — Bíblia e Devocional. Sua jornada espiritual, todos os dias.</h1>

  <div class="hero-chrome">
    <div class="hero-badges">
      <StoreBadge
        variant="google-play"
        href="https://play.google.com/store/apps/details?id=com.gabriel.biblia"
        size="md"
      />
      <StoreBadge
        variant="app-store"
        disabled
        size="md"
      />
    </div>
    <p class="hero-hint">iOS em breve</p>

    <!-- Scroll cue — chevron-down from Lucide (https://lucide.dev/icons/chevron-down) -->
    <a href="#personalization" class="hero-scroll-cue" aria-label="Rolar para próxima seção">
      <!-- lucide:chevron-down, MIT license, https://lucide.dev -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </a>
  </div>
</Panel>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .hero-chrome {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem 1rem 2.5rem;
    text-align: center;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    align-items: center;
  }

  .hero-hint {
    font-family: var(--font-family-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    color: rgba(250, 247, 240, 0.5);
    margin: 0;
  }

  .hero-scroll-cue {
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(250, 247, 240, 0.45);
    transition: color 200ms, transform 200ms;
    margin-top: 0.5rem;
    border-radius: 50%;
    padding: 0.25rem;
  }

  .hero-scroll-cue:hover,
  .hero-scroll-cue:focus-visible {
    color: rgba(250, 247, 240, 0.9);
    transform: translateY(4px);
    outline: 2px solid rgba(212, 175, 55, 0.4);
    outline-offset: 2px;
  }

  /* On desktop the chrome floats below the contained PNG */
  @media (min-width: 640px) {
    .hero-chrome {
      padding: 2rem 1rem 0;
    }
  }
</style>
