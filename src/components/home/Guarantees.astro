---
/**
 * Guarantees.astro — v4 light (NOVA seção)
 *
 * 4 objection killers em grid. Desktop: 4 colunas, mobile: 2×2.
 * Ícones SVG Lucide inline (MIT). Gold-deep em ícones, navy em texto.
 * Background: bg-base (white) — respiro entre HowItWorks alt e FAQ.
 *
 * Block source: HyperUI "Feature grid" adaptado (free, MIT)
 * https://www.hyperui.dev/components/marketing/features
 * Lucide icons: https://lucide.dev | MIT License
 */
---

<section
  class="guarantees"
  aria-label="Garantias e características do app"
>
  <div class="guarantees-inner">

    <!-- Card 1: Sem cadastro -->
    <div class="guarantee-card">
      <!-- Lucide: unlock icon — MIT License — https://lucide.dev/icons/unlock -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="guarantee-icon"
        aria-hidden="true"
      >
        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
        <path d="M7 11V7a5 5 0 0 1 9.9-1"/>
      </svg>
      <p class="guarantee-text">Sem cadastro pra começar</p>
    </div>

    <!-- Card 2: Trial grátis -->
    <div class="guarantee-card">
      <!-- Lucide: gift icon — MIT License — https://lucide.dev/icons/gift -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="guarantee-icon"
        aria-hidden="true"
      >
        <polyline points="20 12 20 22 4 22 4 12"/>
        <rect width="20" height="5" x="2" y="7"/>
        <line x1="12" x2="12" y1="22" y2="7"/>
        <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/>
        <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
      </svg>
      <p class="guarantee-text">Teste 7 dias grátis</p>
    </div>

    <!-- Card 3: Privacidade -->
    <div class="guarantee-card">
      <!-- Lucide: shield icon — MIT License — https://lucide.dev/icons/shield -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="guarantee-icon"
        aria-hidden="true"
      >
        <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
      </svg>
      <p class="guarantee-text">Seus dados ficam com você</p>
    </div>

    <!-- Card 4: Bíblia offline (só a Bíblia roda offline; devocionais/chat precisam de net) -->
    <div class="guarantee-card">
      <!-- Lucide: wifi-off icon — MIT License — https://lucide.dev/icons/wifi-off -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="guarantee-icon"
        aria-hidden="true"
      >
        <path d="M12 20h.01"/>
        <path d="M8.5 16.429a5 5 0 0 1 7 0"/>
        <path d="M5 12.859a10 10 0 0 1 5.17-2.69"/>
        <path d="M19 12.859a10 10 0 0 0-2.007-1.523"/>
        <path d="M2 8.82a15 15 0 0 1 4.177-2.643"/>
        <path d="M22 8.82a15 15 0 0 0-11.288-3.764"/>
        <path d="m2 2 20 20"/>
      </svg>
      <p class="guarantee-text">Bíblia disponível offline</p>
    </div>

  </div>
</section>

<style>
  .guarantees {
    background: var(--color-bg-base);
    padding-block: clamp(4rem, 8vw, 6rem);
    border-top: 1px solid var(--color-divider);
    border-bottom: 1px solid var(--color-divider);
  }

  .guarantees-inner {
    /* polish-iter1: 72rem (era 64rem) — grid de 4 colunas respira melhor em desktop largo. */
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 6vw, 4rem);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  @media (min-width: 768px) {
    .guarantees-inner {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .guarantee-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.875rem;
    padding: clamp(1.25rem, 2vw, 1.75rem);
    border-radius: var(--radius-editorial-lg);
    background: var(--color-bg-alt);
    box-shadow: var(--shadow-card-soft);
  }

  .guarantee-icon {
    color: var(--color-accent-deep);
    flex-shrink: 0;
  }

  .guarantee-text {
    font-family: var(--font-family-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-text-strong);
    margin: 0;
    letter-spacing: -0.005em;
  }
</style>
