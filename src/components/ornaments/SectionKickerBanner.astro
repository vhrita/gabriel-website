---
/**
 * SectionKickerBanner.astro
 * Wrapper CSS-only: RomanNumeral + label Inter caps + FloralDivider mini.
 * Cria a identidade de "capítulo" de manuscrito em cada seção.
 *
 * Fonte: CSS-only (sem SVG externo), tipografia Inter 500 + Fraunces italic.
 * Conforme ADR-0015 §6.1 ornamento #6.
 *
 * Props:
 *   numeral: 'I' | 'II' | 'III' | 'IV'
 *   label: string — texto do kicker em caps
 *   tone: 'on-paper' (default, ink-muted) | 'on-ink' (paper-deep)
 *   showDivider: boolean (default true)
 */

import RomanNumeral from './RomanNumeral.astro';
import FloralDivider from './FloralDivider.astro';

interface Props {
  numeral: 'I' | 'II' | 'III' | 'IV';
  label: string;
  tone?: 'on-paper' | 'on-ink';
  showDivider?: boolean;
  class?: string;
}

const {
  numeral,
  label,
  tone = 'on-paper',
  showDivider = true,
  class: className,
} = Astro.props;

const textColor = tone === 'on-ink'
  ? 'color: var(--color-paper-deep);'
  : 'color: var(--color-ink-muted);';

const dividerColor = tone === 'on-ink'
  ? 'color: var(--color-divine-500); opacity: 0.6;'
  : 'color: var(--color-divine-700); opacity: 0.7;';
---

<div class:list={['section-kicker', className]} style="margin-bottom: 1.5rem;">
  <!-- Kicker linha: numeral + traço + label -->
  <div class="flex items-center gap-3 mb-2">
    <RomanNumeral numeral={numeral} size="small" tone={tone === 'on-ink' ? 'paper' : 'divine'} />
    <span
      class="font-sans font-medium uppercase"
      style={`font-size: 0.6875rem; letter-spacing: 0.1em; ${textColor}`}
    >
      {label}
    </span>
  </div>

  <!-- FloralDivider compacto abaixo do kicker -->
  {showDivider && (
    <FloralDivider
      compact
      width="180px"
      style={dividerColor}
    />
  )}
</div>
