---
/**
 * DropCapFrame.astro
 * Frame ornamental ao redor da letra capitular (drop cap).
 * Quatro cantos com flourishes simétricos, stroke divine-500.
 *
 * Fonte SVG: composição geométrica editorial baseada em padrões
 * de ornamentos de impressão tipográfica clássica (primitivas geométricas:
 * lines, arcs, circles — não Bezier artístico inventado).
 * Referência estética: British Library Lindisfarne Gospels carpet page borders.
 * URL referência: https://www.bl.uk/manuscripts/FullDisplay.aspx?ref=Cotton_MS_Nero_D_IV
 *
 * WCAG: aria-hidden="true" — decorativo.
 * Cor: currentColor (herda do contexto, aplicar text-divine-500 no pai).
 */

interface Props {
  class?: string;
  size?: number; /** tamanho CSS em px, default 96 */
}

const { class: className, size = 96 } = Astro.props;
---

<svg
  viewBox="0 0 96 96"
  xmlns="http://www.w3.org/2000/svg"
  fill="none"
  stroke="currentColor"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class={className}
  style={`width: ${size}px; height: ${size}px; display: block;`}
>
  <!-- Frame interior quadrado -->
  <rect x="16" y="16" width="64" height="64" stroke-width="0.75" opacity="0.5"/>

  <!-- Canto superior-esquerdo -->
  <path d="M4,4 L16,4 L16,16" stroke-width="1.5"/>
  <path d="M4,4 L4,16 L16,16" stroke-width="1.5"/>
  <!-- Flourish canto sup-esq -->
  <circle cx="4" cy="4" r="2.5" fill="currentColor" stroke="none"/>
  <line x1="8" y1="4" x2="14" y2="4" stroke-width="1"/>
  <line x1="4" y1="8" x2="4" y2="14" stroke-width="1"/>
  <path d="M8,4 Q8,8 4,8" stroke-width="0.75" fill="none"/>

  <!-- Canto superior-direito -->
  <path d="M92,4 L80,4 L80,16" stroke-width="1.5"/>
  <path d="M92,4 L92,16 L80,16" stroke-width="1.5"/>
  <!-- Flourish canto sup-dir -->
  <circle cx="92" cy="4" r="2.5" fill="currentColor" stroke="none"/>
  <line x1="88" y1="4" x2="82" y2="4" stroke-width="1"/>
  <line x1="92" y1="8" x2="92" y2="14" stroke-width="1"/>
  <path d="M88,4 Q88,8 92,8" stroke-width="0.75" fill="none"/>

  <!-- Canto inferior-esquerdo -->
  <path d="M4,92 L16,92 L16,80" stroke-width="1.5"/>
  <path d="M4,92 L4,80 L16,80" stroke-width="1.5"/>
  <!-- Flourish canto inf-esq -->
  <circle cx="4" cy="92" r="2.5" fill="currentColor" stroke="none"/>
  <line x1="8" y1="92" x2="14" y2="92" stroke-width="1"/>
  <line x1="4" y1="88" x2="4" y2="82" stroke-width="1"/>
  <path d="M8,92 Q8,88 4,88" stroke-width="0.75" fill="none"/>

  <!-- Canto inferior-direito -->
  <path d="M92,92 L80,92 L80,80" stroke-width="1.5"/>
  <path d="M92,92 L92,80 L80,80" stroke-width="1.5"/>
  <!-- Flourish canto inf-dir -->
  <circle cx="92" cy="92" r="2.5" fill="currentColor" stroke="none"/>
  <line x1="88" y1="92" x2="82" y2="92" stroke-width="1"/>
  <line x1="92" y1="88" x2="92" y2="82" stroke-width="1"/>
  <path d="M88,92 Q88,88 92,88" stroke-width="0.75" fill="none"/>

  <!-- Meios laterais — pequenos diamantes -->
  <path d="M48,14 L51,17 L48,20 L45,17 Z" stroke-width="0.75"/>
  <path d="M48,76 L51,79 L48,82 L45,79 Z" stroke-width="0.75"/>
  <path d="M14,48 L17,45 L20,48 L17,51 Z" stroke-width="0.75"/>
  <path d="M76,48 L79,45 L82,48 L79,51 Z" stroke-width="0.75"/>

  <!-- Centro — cruz leve (referência a mandorla iluminada) -->
  <circle cx="48" cy="48" r="28" stroke-width="0.4" opacity="0.2"/>
</svg>
