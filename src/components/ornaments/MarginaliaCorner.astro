---
/**
 * MarginaliaCorner.astro
 * Ornamento de canto estilizado — folhagem/vinha evocando marginalia
 * de manuscritos iluminados. Ocupa canto (default: top-right).
 *
 * Fonte SVG: composição geométrica editorial com arcos e curvas
 * suaves evocando folhagem estilizada. Inspiração em Iconify
 * ph:flower-lotus-light (MIT, https://icon-sets.iconify.design/ph/)
 * e padrão de vine scroll de manuscritos medievais (British Library PD).
 *
 * Referência: https://icon-sets.iconify.design/ph/flower-lotus-light/
 * Implementação: composição própria de arcos simplificados.
 *
 * WCAG: aria-hidden="true" — decorativo.
 * Props:
 *   rotate: 0 | 90 | 180 | 270 (graus CSS, default 0 = top-right)
 */

interface Props {
  class?: string;
  rotate?: 0 | 90 | 180 | 270;
  size?: number;
}

const { class: className, rotate = 0, size = 80 } = Astro.props;
---

<svg
  viewBox="0 0 80 80"
  xmlns="http://www.w3.org/2000/svg"
  fill="none"
  stroke="currentColor"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class={className}
  style={`width: ${size}px; height: ${size}px; display: block; transform: rotate(${rotate}deg); transform-origin: center;`}
>
  <!-- Haste principal em L — âncora do canto top-right -->
  <path d="M80,0 Q80,8 72,12 Q60,18 50,28 Q40,38 36,50 Q32,62 32,80" stroke-width="1.25" opacity="0.8"/>

  <!-- Folha 1 — grande, canto direito -->
  <path d="M72,12 Q78,6 80,0" stroke-width="1" opacity="0.6"/>
  <path d="M68,16 Q62,8 70,4 Q76,6 72,14 Z" stroke-width="0.75" fill="currentColor" fill-opacity="0.06"/>

  <!-- Folha 2 — média, intermediária -->
  <path d="M58,26 Q54,18 62,16 Q68,18 62,26 Z" stroke-width="0.75" fill="currentColor" fill-opacity="0.06"/>

  <!-- Folha 3 — pequena, inclinada -->
  <path d="M46,40 Q42,32 50,30 Q56,32 50,40 Z" stroke-width="0.75" fill="currentColor" fill-opacity="0.06"/>

  <!-- Folha 4 — descendo -->
  <path d="M36,54 Q30,46 38,44 Q44,46 38,54 Z" stroke-width="0.75" fill="currentColor" fill-opacity="0.06"/>

  <!-- Elemento floral no topo — ponto de origem ornamental -->
  <circle cx="78" cy="4" r="2.5" fill="currentColor" opacity="0.4" stroke="none"/>
  <circle cx="78" cy="4" r="4" stroke-width="0.5" opacity="0.3"/>

  <!-- Tenril sutil saindo da haste -->
  <path d="M62,22 Q66,20 64,16" stroke-width="0.75" opacity="0.5"/>
  <path d="M50,34 Q54,32 52,28" stroke-width="0.75" opacity="0.5"/>
  <path d="M40,46 Q44,44 42,40" stroke-width="0.75" opacity="0.5"/>
</svg>
