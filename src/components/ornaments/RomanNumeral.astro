---
/**
 * RomanNumeral.astro
 * Numeral romano estilizado — tipográfico, não SVG.
 * Fraunces 800 italic opsz 96, divine-700.
 * Componente CSS-only conforme ADR-0015 §6.1 ornamento #4.
 *
 * Fonte: tipografia Fraunces Variable (ADR-0015 §11 Q4 — zero Bezier inventado).
 * Uso: Features I-IV, kickers de seção.
 *
 * Props:
 *   numeral: 'I' | 'II' | 'III' | 'IV'
 *   size: 'large' (default, features) | 'small' (kickers)
 *   tone: 'divine' (default) | 'paper' (em fundo escuro)
 */

interface Props {
  numeral: 'I' | 'II' | 'III' | 'IV';
  size?: 'large' | 'small';
  tone?: 'divine' | 'paper';
  class?: string;
}

const { numeral, size = 'large', tone = 'divine', class: className } = Astro.props;

const sizeStyle = size === 'large'
  ? 'font-size: clamp(2.5rem, 5vw, 4rem); font-variation-settings: "opsz" 96, "wght" 800; line-height: 1;'
  : 'font-size: clamp(1rem, 2vw, 1.25rem); font-variation-settings: "opsz" 32, "wght" 700; line-height: 1; letter-spacing: 0.05em;';

const colorStyle = tone === 'divine'
  ? 'color: var(--color-divine-700);'
  : 'color: var(--color-divine-300);';
---

<span
  class:list={['roman-numeral', className]}
  style={`font-family: var(--font-family-display); font-style: italic; ${sizeStyle} ${colorStyle} display: block;`}
  aria-hidden="true"
>
  {numeral}
</span>

<style>
  .roman-numeral {
    font-feature-settings: 'onum' 1, 'lnum' 0;
    -webkit-font-smoothing: antialiased;
  }
</style>
