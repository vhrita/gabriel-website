---
/**
 * CornerFleuron.astro
 * Símbolo isolado — fleuron ornamental para fins de seção e separadores.
 *
 * Fonte: Unicode U+2767 ROTATED FLORAL HEART BULLET (❧)
 * Renderizado em Fraunces Variable — zero custo, escala perfeita,
 * conforme ADR-0015 §6.1 ornamento #7 (preferência Unicode).
 * URL: https://unicode-table.com/en/2767/
 *
 * Fallback visual: se Fraunces não carregar, qualquer serif renderiza ❧.
 * WCAG: aria-hidden="true" — decorativo.
 *
 * Props:
 *   size: 'sm' | 'md' (default) | 'lg'
 *   tone: 'divine' (default) | 'paper' | 'muted'
 */

interface Props {
  size?: 'sm' | 'md' | 'lg';
  tone?: 'divine' | 'paper' | 'muted';
  class?: string;
}

const { size = 'md', tone = 'divine', class: className } = Astro.props;

const fontSize = size === 'sm' ? '0.875rem' : size === 'lg' ? '1.75rem' : '1.25rem';
const color = tone === 'paper'
  ? 'var(--color-paper-deep)'
  : tone === 'muted'
  ? 'var(--color-ink-muted)'
  : 'var(--color-divine-700)';
---

<span
  class:list={['corner-fleuron', className]}
  aria-hidden="true"
  style={`
    font-family: var(--font-family-display);
    font-variation-settings: 'opsz' 32, 'wght' 500;
    font-size: ${fontSize};
    color: ${color};
    display: inline-block;
    line-height: 1;
    -webkit-font-smoothing: antialiased;
  `}
>❧</span>
