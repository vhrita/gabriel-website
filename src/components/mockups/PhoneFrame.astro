---
/**
 * PhoneFrame.astro — v3
 *
 * Phone frame CSS puro (bezel + notch + home indicator + drop-shadow).
 * Carrega um único <img> em /screens/v3/{slug}.jpeg.
 * SEM nenhum markup fake dentro do screen (anti-pattern PRs 2–5).
 *
 * polish-leva3b (2026-05-26): prints REAIS do app integrados (dark mode —
 * intencional, padrão Linear/Apple: phone dark sobre site light). JPEG, não PNG:
 * conteúdo fotográfico (gradientes/foto de fundo) comprime muito melhor em JPEG.
 * Slots: devocional · bible · chat · verse · letter · home (hero).
 */

interface Props {
  /** Slug do screen — define o path do JPEG carregado */
  screen: 'devocional' | 'bible' | 'chat' | 'verse' | 'letter' | 'home';
  /** Alt text descritivo PT-BR (a11y) */
  alt: string;
  /** Tamanho do frame (controla a largura, aspect lock) */
  size?: 'sm' | 'md' | 'lg';
  /** Indica se a imagem deve ser carregada com prioridade (hero) */
  priority?: boolean;
  /** Classe extra */
  class?: string;
}

const { screen, alt, size = 'md', priority = false, class: className } = Astro.props;
// sm: feature rows (massa equilibrada com texto, encurta mobile) · md: default · lg: hero
const width = size === 'lg' ? 320 : size === 'sm' ? 192 : 280;
const aspect = 19.5 / 9; // iPhone 14-like
const height = Math.round(width * aspect);
const screenSrc = `/screens/v3/${screen}.jpeg`;
const styleAttr = [
  `width: ${width}px`,
  `--phone-h: ${height}px`,
].filter(Boolean).join('; ');
---

<div
  class:list={['phone-frame', `phone-frame--${size}`, className]}
  style={styleAttr}
  role="img"
  aria-label={alt}
>
  <div class="phone-frame__bezel" aria-hidden="true">
    <div class="phone-frame__notch" aria-hidden="true"></div>
    <div class="phone-frame__speaker" aria-hidden="true"></div>
    <div class="phone-frame__screen">
      <img
        src={screenSrc}
        alt=""
        aria-hidden="true"
        width={width - 24}
        height={height - 24}
        loading={priority ? 'eager' : 'lazy'}
        decoding="async"
        class="phone-frame__img"
      />
    </div>
    <div class="phone-frame__home-indicator" aria-hidden="true"></div>
  </div>
</div>

<style>
  .phone-frame {
    position: relative;
    display: inline-block;
    aspect-ratio: 9 / 19.5;
    transition: transform 300ms ease, filter 300ms ease;
  }

  .phone-frame__bezel {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #0a0d12 0%, #1c2128 100%);
    border-radius: 44px;
    padding: 12px;
    box-shadow:
      var(--shadow-phone-frame),
      inset 0 0 0 1.5px rgba(255, 255, 255, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.10);
  }

  .phone-frame__notch {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    width: 38%;
    height: 22px;
    background: #0a0d12;
    border-radius: 14px;
    z-index: 2;
  }

  .phone-frame__speaker {
    /* Pequeno detalhe no topo do bezel (subtle realism) */
    position: absolute;
    top: 22px;
    left: 50%;
    transform: translateX(-50%);
    width: 32%;
    height: 4px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 2px;
    z-index: 3;
    pointer-events: none;
  }

  .phone-frame__screen {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 32px;
    overflow: hidden;
    background: var(--color-bg-dark-alt); /* fallback se o PNG não carregar */
  }

  .phone-frame__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .phone-frame__home-indicator {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 30%;
    height: 4px;
    background: rgba(255, 255, 255, 0.30);
    border-radius: 2px;
    z-index: 2;
  }

  @media (hover: hover) {
    .phone-frame:hover {
      transform: translateY(-4px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .phone-frame,
    .phone-frame:hover {
      transform: none !important;
      transition: none !important;
    }
  }
</style>
