---
/**
 * AppMockup.astro
 * Phone frame SVG inline + conteúdo HTML real por screen.
 * Home v2 "Type as Sky" — zero libs, zero stock photos.
 *
 * Props:
 *   screen: 'devocional' | 'biblia' | 'streak' | 'chat'
 *   class?: string
 *   tilt?: number   — graus de rotação CSS (ex: -2, 3). 0 = sem tilt.
 *   size?: 'md' | 'lg'  — md=260px, lg=320px
 */

interface Props {
  screen: 'devocional' | 'biblia' | 'streak' | 'chat';
  class?: string;
  tilt?: number;
  size?: 'md' | 'lg';
}

const {
  screen,
  class: className,
  tilt = 0,
  size = 'md',
} = Astro.props;

const width = size === 'lg' ? 320 : 260;
const frameStyle = [
  `width: ${width}px`,
  tilt !== 0 ? `transform: rotate(${tilt}deg)` : '',
].filter(Boolean).join('; ');
---

<div
  class:list={['app-mockup', `app-mockup--${size}`, `app-mockup--${screen}`, className]}
  style={frameStyle}
  aria-label={`Tela do app Gabriel: ${screen}`}
  role="img"
>
  <!-- Phone frame SVG -->
  <svg
    class="app-mockup__frame"
    viewBox="0 0 280 560"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <!-- Bezel outer -->
    <rect x="1.5" y="1.5" width="277" height="557" rx="38.5" fill="#1A1814" stroke="#1A1814" stroke-width="3"/>
    <!-- Screen area bg -->
    <rect x="10" y="10" width="260" height="540" rx="30" fill="#FAF7F0"/>
    <!-- Notch pill -->
    <rect x="102" y="14" width="76" height="22" rx="11" fill="#1A1814"/>
    <!-- Status bar: time -->
    <text x="26" y="29" font-family="system-ui, -apple-system, sans-serif" font-size="11" font-weight="600" fill="#1A1814" opacity="0.75">9:41</text>
    <!-- Status bar: signal dots -->
    <circle cx="226" cy="24" r="3" fill="#1A1814" opacity="0.7"/>
    <circle cx="234" cy="24" r="3" fill="#1A1814" opacity="0.7"/>
    <circle cx="242" cy="24" r="3" fill="#1A1814" opacity="0.7"/>
    <!-- Battery outline -->
    <rect x="250" y="19" width="19" height="10" rx="2" stroke="#1A1814" stroke-width="1.5" opacity="0.7"/>
    <rect x="269" y="22" width="2.5" height="4" rx="1" fill="#1A1814" opacity="0.6"/>
    <rect x="251.5" y="20.5" width="13" height="7" rx="1" fill="#1A1814" opacity="0.65"/>
    <!-- Home indicator -->
    <rect x="105" y="542" width="70" height="4" rx="2" fill="#1A1814" opacity="0.25"/>
  </svg>

  <!-- Screen content — absolute inside frame -->
  <div class="app-mockup__screen">

    {screen === 'devocional' && (
      <div class="screen-devocional">
        <div class="screen-header">
          <span class="screen-date">Hoje · 16 de maio</span>
          <div class="screen-icons">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          </div>
        </div>
        <div class="screen-card">
          <p class="screen-verse-ref">Salmo 119:105</p>
          <h3 class="screen-title">A tua palavra é lâmpada</h3>
          <p class="screen-body">Há momentos em que o caminho parece escuro e as escolhas difíceis demais. Deus não promete remover as trevas, mas promete iluminar o próximo passo.</p>
          <p class="screen-body">Hoje, você não precisa ver o caminho inteiro. Precisa apenas dar o próximo passo com o que Ele já revelou. A Palavra não é um mapa completo — é uma lanterna.</p>
          <p class="screen-body screen-body--quote">"Não deixes apagar a tua luz em mim."</p>
        </div>
        <div class="screen-footer-actions">
          <button class="screen-action" aria-label="Salvar devocional">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            <span>Salvar</span>
          </button>
          <button class="screen-action" aria-label="Compartilhar devocional">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            <span>Compartilhar</span>
          </button>
          <button class="screen-action" aria-label="Ver comentários">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <span>14</span>
          </button>
        </div>
      </div>
    )}

    {screen === 'biblia' && (
      <div class="screen-biblia">
        <div class="screen-header">
          <div>
            <h3 class="screen-garden-title">Jardim da Fé</h3>
            <p class="screen-garden-sub">12 livros completos · 54 a caminho</p>
          </div>
        </div>
        <div class="screen-progress-list">
          <div class="screen-progress-item">
            <div class="screen-progress-top">
              <span class="screen-book-name">Mateus</span>
              <span class="screen-book-pct">80%</span>
            </div>
            <div class="screen-progress-bar"><div class="screen-progress-fill" style="width:80%"></div></div>
          </div>
          <div class="screen-progress-item">
            <div class="screen-progress-top">
              <span class="screen-book-name">Marcos</span>
              <span class="screen-book-pct">45%</span>
            </div>
            <div class="screen-progress-bar"><div class="screen-progress-fill" style="width:45%"></div></div>
          </div>
          <div class="screen-progress-item">
            <div class="screen-progress-top">
              <span class="screen-book-name">Lucas</span>
              <span class="screen-book-pct">12%</span>
            </div>
            <div class="screen-progress-bar"><div class="screen-progress-fill" style="width:12%"></div></div>
          </div>
          <div class="screen-progress-item">
            <div class="screen-progress-top">
              <span class="screen-book-name">João</span>
              <span class="screen-book-pct screen-book-pct--zero">Não iniciado</span>
            </div>
            <div class="screen-progress-bar"><div class="screen-progress-fill" style="width:0%"></div></div>
          </div>
          <div class="screen-progress-item">
            <div class="screen-progress-top">
              <span class="screen-book-name">Gênesis</span>
              <span class="screen-book-pct">100%</span>
            </div>
            <div class="screen-progress-bar"><div class="screen-progress-fill screen-progress-fill--complete" style="width:100%"></div></div>
          </div>
          <div class="screen-progress-item">
            <div class="screen-progress-top">
              <span class="screen-book-name">Salmos</span>
              <span class="screen-book-pct">63%</span>
            </div>
            <div class="screen-progress-bar"><div class="screen-progress-fill" style="width:63%"></div></div>
          </div>
        </div>
        <div class="screen-lang-row">
          <span class="screen-lang screen-lang--active">PT</span>
          <span class="screen-lang">EN</span>
          <span class="screen-lang">ES</span>
        </div>
      </div>
    )}

    {screen === 'streak' && (
      <div class="screen-streak">
        <div class="screen-header">
          <span class="screen-date">Sua constância</span>
        </div>
        <div class="screen-streak-main">
          <div class="screen-flame" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12 2C12 2 8 7 8 11C8 13.21 9.79 15 12 15C14.21 15 16 13.21 16 11C16 9 15 8 15 8C15 8 16 12 13 13C13 13 14 10 12 8C12 8 13 11 11 12C11 12 9.5 10.5 9.5 9C9.5 6 12 2 12 2Z" fill="#D4AF37"/>
              <path d="M12 15C9.79 15 8 16.79 8 19C8 21.21 9.79 23 12 23C14.21 23 16 21.21 16 19C16 16.79 14.21 15 12 15Z" fill="#D4AF37" opacity="0.6"/>
            </svg>
          </div>
          <div class="screen-streak-number">8</div>
          <div class="screen-streak-label">dias seguidos</div>
          <div class="screen-streak-sub">Melhor: 21 dias</div>
        </div>
        <div class="screen-calendar" aria-label="Calendário da semana">
          <div class="screen-cal-row">
            {['D','S','T','Q','Q','S','S'].map((d) => (
              <span class="screen-cal-day-label">{d}</span>
            ))}
          </div>
          <div class="screen-cal-grid">
            {[false,false,false,false,true,true,true,true,true,true,true,true,true,false,false,false,false,false,false,false,false,false,false,false,false,false,false,false].map((marked, i) => (
              <div class:list={['screen-cal-dot', marked ? 'screen-cal-dot--marked' : '', i === 13 ? 'screen-cal-dot--today' : '']}></div>
            ))}
          </div>
        </div>
        <div class="screen-streak-cta">Continue hoje →</div>
      </div>
    )}

    {screen === 'chat' && (
      <div class="screen-chat">
        <div class="screen-header">
          <div class="screen-chat-avatar" aria-hidden="true">G</div>
          <div>
            <span class="screen-chat-name">Gabriel</span>
            <span class="screen-chat-online">online agora</span>
          </div>
        </div>
        <div class="screen-messages">
          <div class="screen-msg screen-msg--in">
            <p>Pode me explicar Mateus 5:14?</p>
            <span class="screen-msg-time">14:22</span>
          </div>
          <div class="screen-msg screen-msg--out">
            <p>Em Mateus 5:14, Jesus chama seus seguidores de "luz do mundo". Assim como uma cidade no alto de um monte não pode ser escondida, quem vive segundo o Reino não consegue passar despercebido.</p>
            <span class="screen-msg-time">14:22</span>
          </div>
          <div class="screen-msg screen-msg--in">
            <p>Como isso se aplica no dia a dia?</p>
            <span class="screen-msg-time">14:23</span>
          </div>
          <div class="screen-msg screen-msg--out">
            <p>Na prática: suas escolhas, palavras e atitudes revelam (ou escondem) sua fé. Você não precisa pregar — só precisas ser.</p>
            <span class="screen-msg-time">14:23</span>
          </div>
        </div>
        <div class="screen-chat-input">
          <span class="screen-chat-placeholder">Pergunte sobre a Bíblia...</span>
        </div>
      </div>
    )}

  </div>
</div>

<style>
  .app-mockup {
    position: relative;
    display: inline-block;
    filter: drop-shadow(0 8px 24px rgba(26, 24, 20, 0.12));
    transition: transform 300ms ease, filter 300ms ease;
  }

  @media (hover: hover) {
    .app-mockup:hover {
      transform: scale(1.02) rotate(0deg);
      filter: drop-shadow(0 16px 36px rgba(26, 24, 20, 0.18));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .app-mockup {
      transform: none !important;
      transition: none !important;
    }
    .app-mockup:hover {
      transform: none !important;
    }
  }

  .app-mockup__frame {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Screen area — absolute positioned over the SVG frame */
  .app-mockup__screen {
    position: absolute;
    /* These percentages map to the SVG screen rect: x=10/280=3.57%, y=44/560=7.86% (after status bar), w=260/280=92.86%, h=490/560 */
    top: 7.86%;
    left: 3.57%;
    width: 92.86%;
    height: 84.64%;
    background: #FAF7F0;
    border-radius: 0 0 28px 28px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ==================
     SHARED SCREEN PARTS
     ================== */
  .screen-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0.75rem 0.5rem;
    border-bottom: 1px solid rgba(26, 24, 20, 0.06);
  }

  .screen-date {
    font-family: var(--font-family-sans);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  .screen-icons {
    display: flex;
    gap: 0.5rem;
    color: var(--color-ink-muted);
  }

  /* ==================
     DEVOCIONAL SCREEN
     ================== */
  .screen-devocional {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .screen-card {
    flex: 1;
    padding: 0.75rem;
    overflow: hidden;
  }

  .screen-verse-ref {
    font-family: var(--font-family-sans);
    font-size: 0.5rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-divine-700);
    margin: 0 0 0.25rem;
  }

  .screen-title {
    font-family: var(--font-family-display);
    font-variation-settings: 'opsz' 32, 'wght' 700;
    font-size: 0.85rem;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
  }

  .screen-body {
    font-family: var(--font-family-serif);
    font-variation-settings: 'opsz' 12;
    font-size: 0.55rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
    margin: 0 0 0.375rem;
  }

  .screen-body--quote {
    font-style: italic;
    color: var(--color-ink-muted);
    border-left: 2px solid var(--color-divine-500);
    padding-left: 0.4rem;
    margin-top: 0.5rem;
  }

  .screen-footer-actions {
    display: flex;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-top: 1px solid rgba(26, 24, 20, 0.06);
  }

  .screen-action {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-family-sans);
    font-size: 0.5rem;
    font-weight: 500;
    color: var(--color-ink-muted);
    background: none;
    border: none;
    cursor: default;
    padding: 0;
  }

  /* ==================
     BIBLIA SCREEN
     ================== */
  .screen-biblia {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 0;
  }

  .screen-garden-title {
    font-family: var(--font-family-display);
    font-variation-settings: 'opsz' 24, 'wght' 700;
    font-size: 0.85rem;
    color: var(--color-ink);
    margin: 0;
    line-height: 1.1;
  }

  .screen-garden-sub {
    font-family: var(--font-family-sans);
    font-size: 0.5rem;
    color: var(--color-ink-muted);
    margin: 0.1rem 0 0;
  }

  .screen-progress-list {
    flex: 1;
    padding: 0.5rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    overflow: hidden;
  }

  .screen-progress-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .screen-progress-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .screen-book-name {
    font-family: var(--font-family-sans);
    font-size: 0.55rem;
    font-weight: 500;
    color: var(--color-ink);
  }

  .screen-book-pct {
    font-family: var(--font-family-sans);
    font-size: 0.5rem;
    font-weight: 600;
    color: var(--color-garden-500);
  }

  .screen-book-pct--zero {
    color: var(--color-ink-muted);
    font-weight: 400;
  }

  .screen-progress-bar {
    height: 4px;
    background: rgba(74, 124, 89, 0.12);
    border-radius: 2px;
    overflow: hidden;
  }

  .screen-progress-fill {
    height: 100%;
    background: var(--color-garden-500);
    border-radius: 2px;
    transition: width 600ms ease;
  }

  .screen-progress-fill--complete {
    background: var(--color-garden-700);
  }

  .screen-lang-row {
    display: flex;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border-top: 1px solid rgba(26, 24, 20, 0.06);
  }

  .screen-lang {
    font-family: var(--font-family-sans);
    font-size: 0.5rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-ink-muted);
    padding: 0.2rem 0.35rem;
    border-radius: 4px;
  }

  .screen-lang--active {
    background: var(--color-celestial-700);
    color: var(--color-paper);
  }

  /* ==================
     STREAK SCREEN
     ================== */
  .screen-streak {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .screen-streak-main {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.75rem 0 0.5rem;
    gap: 0.1rem;
  }

  .screen-flame {
    margin-bottom: 0.1rem;
  }

  .screen-streak-number {
    font-family: var(--font-family-display);
    font-variation-settings: 'opsz' 96, 'wght' 800;
    font-size: 2.5rem;
    line-height: 1;
    color: var(--color-ink);
    letter-spacing: -0.04em;
  }

  .screen-streak-label {
    font-family: var(--font-family-sans);
    font-size: 0.55rem;
    font-weight: 500;
    color: var(--color-ink-soft);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .screen-streak-sub {
    font-family: var(--font-family-sans);
    font-size: 0.5rem;
    color: var(--color-ink-muted);
    margin-top: 0.2rem;
  }

  .screen-calendar {
    flex: 1;
    padding: 0.5rem 0.75rem;
  }

  .screen-cal-row {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    margin-bottom: 0.3rem;
  }

  .screen-cal-day-label {
    font-family: var(--font-family-sans);
    font-size: 0.45rem;
    font-weight: 600;
    color: var(--color-ink-muted);
    text-align: center;
    letter-spacing: 0.05em;
  }

  .screen-cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0.3rem;
  }

  .screen-cal-dot {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: rgba(26, 24, 20, 0.06);
    margin: 0 auto;
  }

  .screen-cal-dot--marked {
    background: var(--color-garden-500);
  }

  .screen-cal-dot--today {
    background: var(--color-divine-500);
    box-shadow: 0 0 0 2px rgba(212, 175, 55, 0.3);
  }

  .screen-streak-cta {
    font-family: var(--font-family-sans);
    font-size: 0.55rem;
    font-weight: 600;
    color: var(--color-divine-700);
    text-align: center;
    padding: 0.5rem 0.75rem;
    border-top: 1px solid rgba(26, 24, 20, 0.06);
  }

  /* ==================
     CHAT SCREEN
     ================== */
  .screen-chat {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .screen-chat-avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--color-celestial-700);
    color: var(--color-paper);
    font-family: var(--font-family-display);
    font-variation-settings: 'opsz' 18, 'wght' 700;
    font-size: 0.65rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .screen-chat-name {
    font-family: var(--font-family-sans);
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--color-ink);
    display: block;
    line-height: 1.2;
  }

  .screen-chat-online {
    font-family: var(--font-family-sans);
    font-size: 0.45rem;
    color: var(--color-garden-500);
    display: block;
  }

  .screen-messages {
    flex: 1;
    padding: 0.5rem 0.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    overflow: hidden;
  }

  .screen-msg {
    max-width: 82%;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .screen-msg--in {
    align-self: flex-start;
  }

  .screen-msg--out {
    align-self: flex-end;
  }

  .screen-msg p {
    font-family: var(--font-family-serif);
    font-variation-settings: 'opsz' 12;
    font-size: 0.5rem;
    line-height: 1.5;
    margin: 0;
    padding: 0.35rem 0.5rem;
    border-radius: 10px;
  }

  .screen-msg--in p {
    background: rgba(26, 24, 20, 0.07);
    color: var(--color-ink);
    border-bottom-left-radius: 3px;
  }

  .screen-msg--out p {
    background: var(--color-celestial-700);
    color: var(--color-paper);
    border-bottom-right-radius: 3px;
  }

  .screen-msg-time {
    font-family: var(--font-family-sans);
    font-size: 0.4rem;
    color: var(--color-ink-muted);
    padding: 0 0.2rem;
  }

  .screen-msg--out .screen-msg-time {
    text-align: right;
  }

  .screen-chat-input {
    border-top: 1px solid rgba(26, 24, 20, 0.06);
    padding: 0.4rem 0.6rem;
    background: rgba(26, 24, 20, 0.02);
    border-radius: 0 0 26px 26px;
  }

  .screen-chat-placeholder {
    font-family: var(--font-family-sans);
    font-size: 0.5rem;
    color: var(--color-ink-muted);
  }
</style>
