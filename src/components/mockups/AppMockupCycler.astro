---
/**
 * AppMockupCycler.astro
 * Auto-cycles between 4 screens via CSS keyframe opacity.
 * 8s loop total: each screen visible ~2s with 200ms crossfade.
 * prefers-reduced-motion: only devocional, static.
 * polish-v2 (TASK-landing-polish-peek-v2)
 *
 * Props:
 *   size?: 'md' | 'lg' — passed to AppMockup
 *   tilt?: number — applied to the cycler wrapper
 *   class?: string
 */

import AppMockup from './AppMockup.astro';

interface Props {
  size?: 'md' | 'lg';
  tilt?: number;
  class?: string;
}

const {
  size = 'lg',
  tilt = 0,
  class: className,
} = Astro.props;

const width = size === 'lg' ? 320 : 260;
const height = Math.round(width * (560 / 280)); // maintain phone aspect ratio

const tiltStyle = tilt !== 0 ? `transform: rotate(${tilt}deg)` : '';
---

<div
  class:list={['mockup-cycler', className]}
  style={`width: ${width}px; height: ${height}px; ${tiltStyle}`}
  aria-label="Telas do app Gabriel"
  role="img"
>
  <div class="mockup-cycler__frame frame--1">
    <AppMockup screen="devocional" size={size} tilt={0} />
  </div>
  <div class="mockup-cycler__frame frame--2">
    <AppMockup screen="biblia" size={size} tilt={0} />
  </div>
  <div class="mockup-cycler__frame frame--3">
    <AppMockup screen="streak" size={size} tilt={0} />
  </div>
  <div class="mockup-cycler__frame frame--4">
    <AppMockup screen="chat" size={size} tilt={0} />
  </div>
</div>

<style>
  .mockup-cycler {
    position: relative;
    flex-shrink: 0;
  }

  .mockup-cycler__frame {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    opacity: 0;
  }

  /* Each frame gets 8s / 4 = 2s of face time.
     Keyframe: fade in at 0%, full at ~3%, full at ~22%, fade out at ~25%, invisible rest.
     Offsets: frame 1 = 0%, frame 2 = 25%, frame 3 = 50%, frame 4 = 75% */

  @keyframes cycler-fade {
    0%    { opacity: 0; }
    3%    { opacity: 1; }
    22%   { opacity: 1; }
    25%   { opacity: 0; }
    100%  { opacity: 0; }
  }

  .frame--1 {
    animation: cycler-fade 8s ease-in-out infinite;
    animation-delay: 0s;
  }
  .frame--2 {
    animation: cycler-fade 8s ease-in-out infinite;
    animation-delay: 2s;
  }
  .frame--3 {
    animation: cycler-fade 8s ease-in-out infinite;
    animation-delay: 4s;
  }
  .frame--4 {
    animation: cycler-fade 8s ease-in-out infinite;
    animation-delay: 6s;
  }

  /* prefers-reduced-motion: only devocional, static */
  @media (prefers-reduced-motion: reduce) {
    .frame--1 {
      opacity: 1;
      animation: none;
    }
    .frame--2,
    .frame--3,
    .frame--4 {
      opacity: 0;
      animation: none;
    }
  }
</style>
