---
/**
 * WingsTransition.astro
 * Seção de transição Hero → céu azul.
 * SVG de asas line-art inline (placeholder honesto, v2 contrata ilustrador).
 * Reveal scroll-driven via WingsReveal.client.ts (Motion One).
 *
 * Decisão de design: SVG inline (não wings.svg.astro separado) para manter
 * o componente auto-contido e simplificar importação do island.
 */
---

<section
  id="wings-transition"
  class="relative h-[60vh] overflow-hidden bg-gradient-to-b from-white via-white to-celestial-400"
  aria-hidden="true"
>
  <div
    id="wings-clip"
    class="absolute inset-0 flex items-center justify-center"
    style="clip-path: inset(100% 0 0 0);"
  >
    <!--
      SVG asas line-art — placeholder honesto.
      viewBox: 0 0 800 320
      Estrutura:
        <g id="wings">
          <g id="wing-left">  — 4 paths de camadas de pena
          <g id="wing-right"> — espelhado via transform scale(-1,1)
      stroke: celestial-700 (#162B49)
      fill: none
      stroke-width: variável 1.5–2.2px
      Bezier cúbicos para curvatura orgânica.
    -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 800 320"
      width="80vw"
      style="max-width: 900px; min-width: 280px;"
      fill="none"
      stroke="#162B49"
      stroke-linecap="round"
      stroke-linejoin="round"
      role="img"
      aria-label="Asas abertas — símbolo do aplicativo Gabriel"
    >
      <g id="wings">

        <!-- Asa esquerda — origem no centro (400,180), abre para a esquerda -->
        <g id="wing-left">
          <!-- Camada 1: contorno externo principal (pena longa, traço mais espesso) -->
          <path
            d="M 400,180
               C 370,160 320,120 260,90
               C 200,60 140,50 80,58
               C 50,62 20,72 10,88
               C 30,100 80,108 140,112
               C 200,116 270,118 340,145
               C 365,155 385,168 400,180 Z"
            stroke-width="2.0"
            opacity="0.95"
          />
          <!-- Camada 2: pena secundária, levemente acima -->
          <path
            d="M 400,175
               C 372,155 328,115 274,86
               C 224,60 168,48 110,54
               C 76,58 44,70 28,86
               C 60,94 112,100 172,106
               C 230,112 300,116 360,138
               C 378,146 392,162 400,175 Z"
            stroke-width="1.8"
            opacity="0.75"
          />
          <!-- Camada 3: pena intermediária, mais curta -->
          <path
            d="M 400,172
               C 376,154 338,118 292,92
               C 248,70 200,60 152,66
               C 120,70 90,82 72,96
               C 104,102 156,108 212,114
               C 264,120 328,124 374,144
               C 388,150 396,162 400,172 Z"
            stroke-width="1.6"
            opacity="0.55"
          />
          <!-- Camada 4: pena interna, cobertura de base -->
          <path
            d="M 400,170
               C 380,156 348,126 310,104
               C 272,84 232,76 196,80
               C 168,84 144,96 132,110
               C 160,114 202,118 248,124
               C 292,130 344,136 382,152
               C 394,158 400,166 400,170 Z"
            stroke-width="1.5"
            opacity="0.38"
          />
          <!-- Nervura central da asa esquerda -->
          <path
            d="M 400,180 C 360,162 300,128 220,96 C 160,72 100,60 50,68"
            stroke-width="2.2"
            opacity="0.90"
            fill="none"
          />
          <!-- Detalhes de penas (linhas finas internas) -->
          <path
            d="M 340,145 C 310,132 270,114 220,96"
            stroke-width="1.2"
            opacity="0.50"
            fill="none"
          />
          <path
            d="M 280,130 C 252,118 218,104 176,90"
            stroke-width="1.2"
            opacity="0.45"
            fill="none"
          />
          <path
            d="M 220,114 C 196,104 164,94 130,88"
            stroke-width="1.1"
            opacity="0.40"
            fill="none"
          />
        </g>

        <!-- Asa direita — espelho exato via transform -->
        <g id="wing-right" transform="scale(-1,1) translate(-800,0)">
          <!-- Camada 1: contorno externo principal -->
          <path
            d="M 400,180
               C 370,160 320,120 260,90
               C 200,60 140,50 80,58
               C 50,62 20,72 10,88
               C 30,100 80,108 140,112
               C 200,116 270,118 340,145
               C 365,155 385,168 400,180 Z"
            stroke-width="2.0"
            opacity="0.95"
          />
          <!-- Camada 2: pena secundária -->
          <path
            d="M 400,175
               C 372,155 328,115 274,86
               C 224,60 168,48 110,54
               C 76,58 44,70 28,86
               C 60,94 112,100 172,106
               C 230,112 300,116 360,138
               C 378,146 392,162 400,175 Z"
            stroke-width="1.8"
            opacity="0.75"
          />
          <!-- Camada 3: pena intermediária -->
          <path
            d="M 400,172
               C 376,154 338,118 292,92
               C 248,70 200,60 152,66
               C 120,70 90,82 72,96
               C 104,102 156,108 212,114
               C 264,120 328,124 374,144
               C 388,150 396,162 400,172 Z"
            stroke-width="1.6"
            opacity="0.55"
          />
          <!-- Camada 4: pena interna -->
          <path
            d="M 400,170
               C 380,156 348,126 310,104
               C 272,84 232,76 196,80
               C 168,84 144,96 132,110
               C 160,114 202,118 248,124
               C 292,130 344,136 382,152
               C 394,158 400,166 400,170 Z"
            stroke-width="1.5"
            opacity="0.38"
          />
          <!-- Nervura central -->
          <path
            d="M 400,180 C 360,162 300,128 220,96 C 160,72 100,60 50,68"
            stroke-width="2.2"
            opacity="0.90"
            fill="none"
          />
          <!-- Detalhes de penas -->
          <path
            d="M 340,145 C 310,132 270,114 220,96"
            stroke-width="1.2"
            opacity="0.50"
            fill="none"
          />
          <path
            d="M 280,130 C 252,118 218,104 176,90"
            stroke-width="1.2"
            opacity="0.45"
            fill="none"
          />
          <path
            d="M 220,114 C 196,104 164,94 130,88"
            stroke-width="1.1"
            opacity="0.40"
            fill="none"
          />
        </g>

      </g>
    </svg>
  </div>
</section>

<script>
  import './WingsReveal.client.ts';
</script>
