---
/**
 * VerseMarquee.astro
 * Banner estático com versículo bíblico em destaque.
 * ADR-0015 §11 Q6: estático com 1 versículo, sem rotação animada.
 * Versículo: Sl 119:105 (ADR-0015 §11 Q2).
 *
 * bg: paper-deep, ~80px height
 * Tipografia: Newsreader 400 italic opsz display, ink-muted
 * Separadores: CornerFleuron ❧ divine-700
 * WCAG: aria-hidden="true" — decorativo (versículos não são conteúdo crítico)
 */

import CornerFleuron from '../ornaments/CornerFleuron.astro';

interface Verse {
  text: string;
  ref: string;
}

interface Props {
  /** Versículos opcionais — default Sl 119:105 */
  verses?: Verse[];
  class?: string;
}

const {
  verses = [
    { text: 'A tua palavra é lâmpada que ilumina os meus passos', ref: 'Sl 119:105' },
  ],
  class: className,
} = Astro.props;

// Exibe apenas o primeiro versículo (decisão Q6: estático)
const verse = verses[0];
---

<div
  class:list={['verse-marquee', className]}
  aria-hidden="true"
  style="
    background-color: var(--color-paper-deep);
    border-top: 1px solid rgba(26, 24, 20, 0.06);
    border-bottom: 1px solid rgba(26, 24, 20, 0.06);
    padding: 1.25rem 1rem;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    min-height: 72px;
    overflow: hidden;
  "
>
  <CornerFleuron size="sm" tone="divine" />

  <p style="
    font-family: var(--font-family-serif);
    font-variation-settings: 'opsz' 28;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(0.875rem, 1.2vw, 1rem);
    color: var(--color-ink-muted);
    line-height: 1.5;
    margin: 0;
    max-width: 55ch;
  ">
    <span style="color: var(--color-divine-700); margin-right: 0.35em; font-style: normal; font-size: 1.1em;">«</span>
    {verse.text}
    <span style="color: var(--color-divine-700); margin-left: 0.35em; font-style: normal; font-size: 1.1em;">»</span>
    <cite style="
      font-family: var(--font-family-sans);
      font-style: normal;
      font-size: 0.625rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-ink-muted);
      margin-left: 0.75em;
      opacity: 0.7;
    ">{verse.ref}</cite>
  </p>

  <CornerFleuron size="sm" tone="divine" />
</div>
