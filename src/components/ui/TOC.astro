---
interface Section {
  id: string;
  title: string;
}

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---

<!-- Mobile: accordion nativo, topo da página -->
<nav aria-label="Índice do documento" class="lg:hidden mb-8">
  <details class="border border-celestial-200 rounded-2xl overflow-hidden">
    <summary class="flex items-center justify-between px-5 py-3 bg-celestial-50 text-celestial-700 font-medium cursor-pointer select-none list-none">
      <span>Conteúdo</span>
      <svg
        class="w-4 h-4 transition-transform duration-200 details-chevron"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
      >
        <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
      </svg>
    </summary>
    <ol class="px-5 py-3 space-y-1 bg-white">
      {sections.map((section) => (
        <li>
          <a
            href={`#${section.id}`}
            class="block text-sm text-celestial-600 hover:text-celestial-800 py-0.5 transition-colors"
          >
            {section.title}
          </a>
        </li>
      ))}
    </ol>
  </details>
</nav>

<!-- Desktop: sidebar sticky -->
<aside
  aria-label="Índice do documento"
  class="hidden lg:block w-56 flex-shrink-0 sticky top-24 self-start max-h-[calc(100vh-7rem)] overflow-y-auto"
>
  <p class="text-xs font-semibold uppercase tracking-widest text-celestial-400 mb-3">Conteúdo</p>
  <ol class="space-y-1" id="toc-list">
    {sections.map((section) => (
      <li>
        <a
          href={`#${section.id}`}
          data-toc-link={section.id}
          class="block text-sm text-celestial-500 hover:text-celestial-700 py-0.5 transition-colors leading-snug toc-link"
        >
          {section.title}
        </a>
      </li>
    ))}
  </ol>
</aside>

<script>
  // IntersectionObserver para highlight do item ativo no TOC desktop
  // Progressive enhancement: TOC funciona sem JS via hrefs normais
  (function () {
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (!links.length) return;

    const activeClass = ['text-celestial-700', 'font-semibold'];
    const inactiveClass = ['text-celestial-500'];

    function setActive(id: string) {
      links.forEach((link) => {
        const isActive = link.dataset.tocLink === id;
        if (isActive) {
          link.classList.remove(...inactiveClass);
          link.classList.add(...activeClass);
        } else {
          link.classList.remove(...activeClass);
          link.classList.add(...inactiveClass);
        }
      });
    }

    const sectionIds = Array.from(links).map((l) => l.dataset.tocLink!);
    const sections = sectionIds
      .map((id) => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    if (!sections.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        // Encontra a seção mais alta visível
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

        if (visible.length > 0) {
          setActive(visible[0].target.id);
        }
      },
      {
        rootMargin: '-96px 0px -60% 0px',
        threshold: 0,
      }
    );

    sections.forEach((section) => observer.observe(section));
  })();
</script>
