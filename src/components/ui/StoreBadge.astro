---
/**
 * StoreBadge.astro
 * Official store badges as inline SVG — crisp at any resolution, no external PNGs.
 * polish-v2 (feature/landing-polish-peek-v2)
 *
 * Props:
 *   variant: 'google-play' | 'app-store'
 *   disabled?: boolean — reduces opacity, disables pointer, adds "Em breve" label
 *   href?: string — renders as <a> when provided (and not disabled)
 *   size?: 'md' | 'sm' — md=50px tall (hero), sm=36px tall (footer)
 *   class?: string
 */

interface Props {
  variant: 'google-play' | 'app-store';
  disabled?: boolean;
  href?: string;
  size?: 'md' | 'sm';
  class?: string;
}

const {
  variant,
  disabled = false,
  href,
  size = 'md',
  class: className,
} = Astro.props;

const isLink = !!href && !disabled;
const ariaLabel = variant === 'google-play'
  ? (disabled ? 'Google Play — Em breve' : 'Baixar no Google Play')
  : (disabled ? 'App Store — Em breve' : 'Baixar na App Store');
---

<div
  class:list={['store-badge-wrap', `store-badge-wrap--${size}`, disabled && 'store-badge-wrap--disabled', className]}
>
  {isLink ? (
    <a
      class="store-badge"
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={ariaLabel}
    >
      {variant === 'google-play' && (
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 646 190" class="store-badge__svg" aria-hidden="true" focusable="false">
          <rect width="646" height="190" rx="22" fill="#000000"/>
          <rect x="1.5" y="1.5" width="643" height="187" rx="20.5" stroke="#A6A6A6" stroke-width="3" fill="none"/>
          <path d="M55 50 L55 140 L110 95 Z" fill="#00D2FF" opacity="0.9"/>
          <path d="M55 50 L110 95 L90 82 Z" fill="#00F07A"/>
          <path d="M55 140 L110 95 L90 108 Z" fill="#FF3D3D"/>
          <path d="M90 82 L110 95 L90 108 Z" fill="#FFD700"/>
          <text x="148" y="82" font-family="'Roboto', 'Helvetica Neue', Arial, sans-serif" font-size="24" font-weight="400" fill="white" letter-spacing="1">GET IT ON</text>
          <text x="148" y="130" font-family="'Roboto', 'Helvetica Neue', Arial, sans-serif" font-size="46" font-weight="500" fill="white">Google Play</text>
        </svg>
      )}
      {variant === 'app-store' && (
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 646 190" class="store-badge__svg" aria-hidden="true" focusable="false">
          <rect width="646" height="190" rx="22" fill="#000000"/>
          <rect x="1.5" y="1.5" width="643" height="187" rx="20.5" stroke="#A6A6A6" stroke-width="3" fill="none"/>
          <path d="M96 58c-6 0-12 3.5-15.5 9-3.5-5.5-9.5-9-15.5-9-11 0-20 9-20 22s9 27 20 34c4 2.5 9 2.5 15.5 0 6.5 2.5 11.5 2.5 15.5 0 11-7 20-21 20-34 0-13-9-22-20-22zm-5-14c2.5-3 4-7 3.5-11-3.5.5-8 2.5-10.5 6-2.5 3-4 7-3.5 11 3.5-.5 8-2.5 10.5-6z" fill="white"/>
          <text x="148" y="82" font-family="'Roboto', 'Helvetica Neue', Arial, sans-serif" font-size="24" font-weight="400" fill="white" letter-spacing="1">Download on the</text>
          <text x="148" y="130" font-family="'Roboto', 'Helvetica Neue', Arial, sans-serif" font-size="46" font-weight="500" fill="white">App Store</text>
        </svg>
      )}
    </a>
  ) : (
    <span class="store-badge" role="img" aria-label={ariaLabel}>
      {variant === 'google-play' && (
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 646 190" class="store-badge__svg" aria-hidden="true" focusable="false">
          <rect width="646" height="190" rx="22" fill="#000000"/>
          <rect x="1.5" y="1.5" width="643" height="187" rx="20.5" stroke="#A6A6A6" stroke-width="3" fill="none"/>
          <path d="M55 50 L55 140 L110 95 Z" fill="#00D2FF" opacity="0.9"/>
          <path d="M55 50 L110 95 L90 82 Z" fill="#00F07A"/>
          <path d="M55 140 L110 95 L90 108 Z" fill="#FF3D3D"/>
          <path d="M90 82 L110 95 L90 108 Z" fill="#FFD700"/>
          <text x="148" y="82" font-family="'Roboto', 'Helvetica Neue', Arial, sans-serif" font-size="24" font-weight="400" fill="white" letter-spacing="1">GET IT ON</text>
          <text x="148" y="130" font-family="'Roboto', 'Helvetica Neue', Arial, sans-serif" font-size="46" font-weight="500" fill="white">Google Play</text>
        </svg>
      )}
      {variant === 'app-store' && (
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 646 190" class="store-badge__svg" aria-hidden="true" focusable="false">
          <rect width="646" height="190" rx="22" fill="#000000"/>
          <rect x="1.5" y="1.5" width="643" height="187" rx="20.5" stroke="#A6A6A6" stroke-width="3" fill="none"/>
          <path d="M96 58c-6 0-12 3.5-15.5 9-3.5-5.5-9.5-9-15.5-9-11 0-20 9-20 22s9 27 20 34c4 2.5 9 2.5 15.5 0 6.5 2.5 11.5 2.5 15.5 0 11-7 20-21 20-34 0-13-9-22-20-22zm-5-14c2.5-3 4-7 3.5-11-3.5.5-8 2.5-10.5 6-2.5 3-4 7-3.5 11 3.5-.5 8-2.5 10.5-6z" fill="white"/>
          <text x="148" y="82" font-family="'Roboto', 'Helvetica Neue', Arial, sans-serif" font-size="24" font-weight="400" fill="white" letter-spacing="1">Download on the</text>
          <text x="148" y="130" font-family="'Roboto', 'Helvetica Neue', Arial, sans-serif" font-size="46" font-weight="500" fill="white">App Store</text>
        </svg>
      )}
    </span>
  )}

  {disabled && (
    <span class="store-badge__soon" aria-hidden="true">Em breve</span>
  )}
</div>

<style>
  .store-badge-wrap {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
  }

  .store-badge-wrap--disabled {
    opacity: 0.55;
    pointer-events: none;
    cursor: not-allowed;
    user-select: none;
  }

  .store-badge {
    display: block;
    text-decoration: none;
    border-radius: 10px;
    transition: opacity 200ms ease, transform 200ms ease;
    overflow: hidden;
  }

  a.store-badge:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  a.store-badge:active {
    transform: translateY(0);
  }

  .store-badge__svg {
    display: block;
    width: auto;
  }

  /* Size: md (hero) — 50px tall */
  .store-badge-wrap--md .store-badge__svg {
    height: 50px;
  }

  /* Size: sm (footer) — 36px tall */
  .store-badge-wrap--sm .store-badge__svg {
    height: 36px;
  }

  .store-badge__soon {
    font-family: var(--font-family-sans);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    display: block;
    text-align: center;
  }
</style>
