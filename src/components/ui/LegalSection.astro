---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<section
  id={id}
  class="scroll-mt-24 pt-8 mt-8 border-t border-celestial-100 first:border-t-0 first:pt-0 first:mt-0"
>
  <h2 class="font-serif font-semibold text-xl text-celestial-700 mb-3 leading-snug">
    {title}
  </h2>
  <div class="prose-legal">
    <slot />
  </div>
</section>
