---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---
<BaseLayout
  title="Página não encontrada — Gabriel"
  description="A página que você procura não existe."
  headerVariant="solid"
  pathname="/404"
>
  <section class="notfound" aria-label="Página não encontrada">
    <div class="notfound-mesh" aria-hidden="true"></div>
    <div class="notfound-content">
      <p class="notfound-eyebrow">e r r o &nbsp; 4 0 4</p>
      <h1 class="notfound-title">
        <span class="notfound-line">Essa página</span>
        <span class="notfound-line">não <em>existe</em>.</span>
      </h1>
      <p class="notfound-sub">
        Talvez você quis dizer outro caminho.<br/>
        Volte pro início e tente de novo.
      </p>
      <div class="notfound-cta">
        <Button variant="primary" href="/">Voltar pro início →</Button>
      </div>
      <p class="notfound-verse">
        <span class="notfound-verse-ref">Sl 25:4</span> — Faze-me saber os teus caminhos, Senhor.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    position: relative;
    min-height: calc(100dvh - 3.5rem);
    background: var(--color-paper);
    display: flex;
    align-items: center;
    padding: 6vw 6vw 4vw;
    overflow: hidden;
  }

  .notfound-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(55vw 45vh at 30% 25%, var(--color-celestial-100), transparent 65%),
      radial-gradient(45vw 40vh at 70% 80%, var(--color-divine-100), transparent 60%);
    filter: blur(8px);
    pointer-events: none;
    opacity: 0.5;
  }

  @media (prefers-reduced-motion: reduce) {
    .notfound-mesh { opacity: 0.35; }
  }

  .notfound-content {
    position: relative;
    z-index: 1;
    max-width: 48rem;
  }

  .notfound-eyebrow {
    font-family: var(--font-family-sans);
    font-weight: 500;
    font-size: 0.8125rem;
    letter-spacing: 0.3em;
    text-transform: lowercase;
    color: var(--color-ink-muted);
    margin: 0 0 3.5rem;
  }

  .notfound-title {
    font-family: var(--font-family-display);
    font-variation-settings: 'opsz' 144, 'wght' 880, 'SOFT' 50, 'WONK' 0;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.92;
    letter-spacing: -0.035em;
    color: var(--color-ink);
    margin: 0 0 2.5rem;
  }

  .notfound-line {
    display: block;
    animation: notfound-line-in 800ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }

  .notfound-line:nth-child(1) { animation-delay: 100ms; }
  .notfound-line:nth-child(2) { animation-delay: 240ms; }

  .notfound-title em {
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'wght' 700, 'SOFT' 100, 'WONK' 1;
  }

  @keyframes notfound-line-in {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .notfound-line {
      animation: none;
    }
  }

  .notfound-sub {
    font-family: var(--font-family-serif);
    font-variation-settings: 'opsz' 28;
    font-weight: 400;
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    line-height: 1.6;
    color: var(--color-ink-soft);
    margin: 0 0 2.5rem;
    max-width: 34rem;
  }

  .notfound-cta {
    margin-bottom: 3.5rem;
  }

  .notfound-verse {
    font-family: var(--font-family-serif);
    font-variation-settings: 'opsz' 14;
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 32rem;
    line-height: 1.55;
  }

  .notfound-verse-ref {
    font-style: normal;
    font-family: var(--font-family-sans);
    font-size: 0.6875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  @media (max-width: 640px) {
    .notfound { padding: 6rem 1.5rem 3rem; }
    .notfound-title { font-size: clamp(2.25rem, 13vw, 4.5rem); }
    .notfound-eyebrow { margin-bottom: 2rem; }
  }
</style>
