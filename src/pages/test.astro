---
/**
 * _test.astro — Smoke test page pra componentes UI base (SUB-3)
 *
 * Esta página é temporária e será deletada em SUB-7.
 * Serve pra verificar visualmente todas as variantes dos componentes base.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import ScrollCue from '../components/ui/ScrollCue.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import Prose from '../components/ui/Prose.astro';
---

<BaseLayout title="Smoke Test — Componentes UI (SUB-3)">

  <!-- ============================================================
       SEÇÃO 1 — bg=white: SectionTitle + Prose + Card + Button primary
       ============================================================ -->
  <Section bg="white">
    <Container>
      <SectionTitle as="h2" align="left" tone="on-light">
        Seção em fundo branco
      </SectionTitle>

      <Prose tone="on-light" class="mt-4 mb-8">
        Este é um parágrafo de exemplo usando o componente <strong>Prose</strong> sobre
        fundo branco (tone on-light). Inter 400, text-base md:text-lg, leading-relaxed,
        max-w-prose. Celestial-700 como cor de texto pra alto contraste.
      </Prose>

      <Card class="mb-8 max-w-sm">
        <h3 class="font-serif font-semibold text-celestial-700 text-lg mb-2">Card de exemplo</h3>
        <p class="font-sans text-sm text-celestial-700/80">
          Fundo heavenly, borda celestial-200, hover eleva -translate-y-1 + shadow-soft.
          Conteúdo via slot.
        </p>
      </Card>

      <Button variant="primary" href="#" as="a">
        CTA Primário — divine-500
      </Button>
    </Container>
  </Section>

  <!-- ============================================================
       SEÇÃO 2 — bg=heavenly: Card + Button secondary + disabled + external
       ============================================================ -->
  <Section bg="heavenly">
    <Container>
      <SectionTitle as="h2" align="center" tone="on-light" class="mb-6">
        Seção em fundo heavenly
      </SectionTitle>

      <Card class="mb-8 max-w-md mx-auto">
        <h3 class="font-serif font-semibold text-celestial-700 text-lg mb-2">Card em heavenly</h3>
        <p class="font-sans text-sm text-celestial-700/80">
          Cards em fundo heavenly ficam sobre a cor base — a diferença é sutil mas perceptível
          (heavenly = #E8F4F8, card bg também heavenly + borda celestial-200 cria separação).
          Em prática, cards ficam melhor sobre white ou celestial-700.
        </p>
      </Card>

      <div class="flex flex-wrap gap-4 justify-center">
        <Button variant="secondary" href="#" as="a">
          CTA Secundário — outline
        </Button>

        <Button variant="disabled" as="button">
          Desabilitado — slate-200
        </Button>

        <Button variant="primary" href="https://play.google.com" as="a" external={true}>
          Link Externo — com ícone
        </Button>
      </div>
    </Container>
  </Section>

  <!-- ============================================================
       SEÇÃO 3 — bg=celestial-gradient: SectionTitle on-dark + Prose on-dark
       ============================================================ -->
  <Section bg="celestial-gradient">
    <Container>
      <SectionTitle as="h2" align="center" tone="on-dark" class="mb-6">
        Seção com gradiente celestial
      </SectionTitle>

      <Prose tone="on-dark" class="mx-auto text-center">
        Texto em fundo gradiente (celestial-400 → celestial-300) usando tone on-dark
        (text-heavenly = #E8F4F8). Legibilidade verificada: contraste adequado sobre
        o azul celestial. Inter 400, leading-relaxed, max-w-prose.
      </Prose>

      <div class="mt-8 flex justify-center">
        <Button variant="primary" href="#" as="a">
          CTA primário sobre gradiente
        </Button>
      </div>
    </Container>
  </Section>

  <!-- ============================================================
       SEÇÃO 4 — bg=celestial-700: relative pra ScrollCue funcionar
       ============================================================ -->
  <Section bg="celestial-700" class="relative min-h-64">
    <Container>
      <SectionTitle as="h2" align="left" tone="on-dark" class="mb-4">
        Seção celestial-700 com ScrollCue
      </SectionTitle>

      <Prose tone="on-dark">
        Fundo celestial-700 (#162B49) — o mais escuro da paleta. ScrollCue abaixo
        (absolute bottom-8 center, animate-bounce, honra prefers-reduced-motion).
        Parent tem <code class="font-mono text-xs bg-white/10 px-1 rounded">relative</code>
        para posicionamento correto do ScrollCue.
      </Prose>
    </Container>

    <ScrollCue />
  </Section>

</BaseLayout>
