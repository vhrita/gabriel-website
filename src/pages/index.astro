---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import HeroPanel from '../components/home/HeroPanel.astro';
import FeatureShowcase from '../components/home/FeatureShowcase.astro';
import PersonalizationPanel from '../components/home/PersonalizationPanel.astro';
import ReflexoesPanel from '../components/home/ReflexoesPanel.astro';
import ChatPanel from '../components/home/ChatPanel.astro';
import JardimPanel from '../components/home/JardimPanel.astro';
import StreakPanel from '../components/home/StreakPanel.astro';
import VersiculoPanel from '../components/home/VersiculoPanel.astro';
import SocialProofPanel from '../components/home/SocialProofPanel.astro';

const jsonLdData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "VHXCO",
    "legalName": "VHXCO",
    "url": "https://vhxco.com.br",
    "taxID": "62.874.893/0001-51",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "vitor@vhxco.com",
      "contactType": "customer support"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    "name": "Gabriel — Bíblia e Devocional",
    "description": "App mobile de crescimento espiritual com devocionais personalizados por IA, leitura bíblica em 3 idiomas e chat com IA contextualizada por religião.",
    "url": "https://gabriel.vhxco.com",
    "operatingSystem": "ANDROID, IOS",
    "applicationCategory": "LifestyleApplication",
    "publisher": {
      "@type": "Organization",
      "name": "VHXCO"
    },
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "BRL",
      "availability": "https://schema.org/InStock"
    }
  }
];
---
<BaseLayout
  title="Gabriel — Sua jornada espiritual, todos os dias"
  description="Devocionais personalizados por IA, a Bíblia inteira em 3 idiomas e conversas com Gabriel sobre fé. Grátis no Google Play."
  headerVariant="transparent"
  headerTone="on-dark"
>
  <JsonLd data={jsonLdData} />

  <!-- Hero panel: standalone, outside the carousel -->
  <HeroPanel />

  <!-- Feature showcase: 7 panels as horizontal scroll-snap on desktop,
       stacked vertically on mobile. SocialProof is separate CTA after. -->
  <FeatureShowcase>
    <PersonalizationPanel />
    <ReflexoesPanel />
    <ChatPanel />
    <JardimPanel />
    <StreakPanel />
    <VersiculoPanel />
  </FeatureShowcase>

  <!-- Social proof + final CTA: outside the carousel, renders as closing section -->
  <SocialProofPanel />
</BaseLayout>
