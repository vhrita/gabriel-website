---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import HeroSection from '../components/home/HeroSection.astro';
import FeaturesIntro from '../components/home/FeaturesIntro.astro';
import FeatureRow from '../components/home/FeatureRow.astro';
import TestimonialSection from '../components/home/TestimonialSection.astro';
import FinalCTA from '../components/home/FinalCTA.astro';

const jsonLdData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "VHXCO",
    "legalName": "VHXCO",
    "url": "https://vhxco.com.br",
    "taxID": "62.874.893/0001-51",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "vitor@vhxco.com",
      "contactType": "customer support"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    "name": "Gabriel — Bíblia e Devocional",
    "description": "App mobile de crescimento espiritual com devocionais personalizados por IA, leitura bíblica em 3 idiomas e chat com IA contextualizada por religião.",
    "url": "https://gabriel.vhxco.com",
    "operatingSystem": "ANDROID, IOS",
    "applicationCategory": "LifestyleApplication",
    "publisher": {
      "@type": "Organization",
      "name": "VHXCO"
    },
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "BRL",
      "availability": "https://schema.org/InStock"
    }
  }
];
---
<BaseLayout
  title="Gabriel — Sua jornada espiritual, todos os dias"
  description="Devocionais personalizados por IA, a Bíblia em 3 idiomas e conversas com Gabriel sobre fé. Grátis no Google Play."
  headerVariant="transparent"
  bodyTheme="light"
>
  <JsonLd data={jsonLdData} />
  <HeroSection />
  <FeaturesIntro />
  <FeatureRow
    num="01"
    textSide="right"
    tone="alt"
    title="Devocional do dia."
    copy="Uma reflexão escrita pra você esta manhã — adaptada à sua tradição (católica, evangélica, espírita ou nenhuma), seus objetivos e sua Carta pra Deus. Pequena, certeira, todo dia diferente."
    screen="devocional"
    alt="Tela de devocional do app Gabriel"
  />
  <FeatureRow
    num="02"
    textSide="left"
    tone="base"
    title="A Bíblia que cresce com você."
    copy="Os 66 livros em português, inglês e espanhol. A cada capítulo lido, seu Jardim da Fé floresce — você vê o caminho que fez."
    screen="bible"
    alt="Tela do Jardim da Fé"
  />
  <FeatureRow
    num="03"
    textSide="right"
    tone="alt"
    title="Um amigo pra conversar."
    copy="Pergunte ao Gabriel sobre fé, Bíblia, dúvidas teológicas. Ele responde consultando a Bíblia — sempre no contexto da sua tradição, sem julgamento."
    screen="chat"
    alt="Tela do chat com Gabriel"
  />
  <FeatureRow
    num="04"
    textSide="left"
    tone="base"
    title="Constância sem culpa."
    copy="Você escolhe a frequência: todo dia, 5×, 3× ou 1× por semana. O streak respeita seu ritmo e celebra cada retorno — não cobra perfeição."
    screen="streak"
    alt="Tela de constância e streak"
  />
  <FeatureRow
    num="05"
    textSide="right"
    tone="alt"
    title="Um versículo por dia."
    copy="Cada manhã, um versículo novo pra começar o dia ou compartilhar com quem você ama. Pequeno gesto, eco longo."
    screen="verse"
    alt="Tela do versículo do dia"
  />
  <TestimonialSection />
  <FinalCTA />
</BaseLayout>
