---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="Gabriel — Seu Guia Espiritual Diário" description="Gabriel: Bíblia e Devocional — Seu guia espiritual com devocionais personalizados por IA, leitura bíblica e muito mais. Em breve no Google Play.">
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">Gabriel</h1>
      <p class="hero-subtitle">Seu guia espiritual diário.</p>
      <p class="hero-description">Devocionais personalizados, leitura bíblica e orientação espiritual com inteligência artificial — tudo em um só app.</p>
      <p class="hero-cta">Em breve no Google Play</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100dvh - 60px - 80px);
    text-align: center;
    padding: var(--space-3xl) 0;
  }

  .hero-title {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--color-text-primary) 0%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-sm);
  }

  .hero-subtitle {
    font-size: clamp(1.125rem, 3vw, 1.375rem);
    color: var(--color-text-secondary);
    font-weight: 400;
    margin-bottom: var(--space-md);
  }

  .hero-description {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    max-width: 420px;
    margin-inline: auto;
    line-height: 1.6;
    margin-bottom: var(--space-xl);
  }

  .hero-cta {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.7;
  }
</style>
